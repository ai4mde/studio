{% raw %}{%{% endraw %} extends "{{ application_name }}_base.html" {% raw %}%}{% endraw %}
{% raw %}{% block content %}{% endraw %}

{# ── Style resolution ── #}
{% set color_map = {
  "blue":   {"btn": "bg-blue-600 hover:bg-blue-700", "light": "bg-blue-50", "text": "text-blue-600", "border": "border-blue-200", "label": "text-blue-700", "ring": "focus:ring-blue-500", "th_bg": "bg-blue-600"},
  "green":  {"btn": "bg-green-600 hover:bg-green-700", "light": "bg-green-50", "text": "text-green-600", "border": "border-green-200", "label": "text-green-700", "ring": "focus:ring-green-500", "th_bg": "bg-green-600"},
  "purple": {"btn": "bg-purple-600 hover:bg-purple-700", "light": "bg-purple-50", "text": "text-purple-600", "border": "border-purple-200", "label": "text-purple-700", "ring": "focus:ring-purple-500", "th_bg": "bg-purple-600"},
  "orange": {"btn": "bg-orange-500 hover:bg-orange-600", "light": "bg-orange-50", "text": "text-orange-500", "border": "border-orange-200", "label": "text-orange-700", "ring": "focus:ring-orange-400", "th_bg": "bg-orange-500"},
  "rose":   {"btn": "bg-rose-600 hover:bg-rose-700", "light": "bg-rose-50", "text": "text-rose-600", "border": "border-rose-200", "label": "text-rose-700", "ring": "focus:ring-rose-500", "th_bg": "bg-rose-600"},
  "slate":  {"btn": "bg-slate-700 hover:bg-slate-800", "light": "bg-slate-50", "text": "text-slate-600", "border": "border-slate-200", "label": "text-slate-700", "ring": "focus:ring-slate-500", "th_bg": "bg-slate-700"},
} %}
{% set c = color_map.get(color, color_map["blue"]) %}

{% set radius_map = {"none": "rounded-none", "sm": "rounded-sm", "md": "rounded-md", "lg": "rounded-lg", "xl": "rounded-xl", "2xl": "rounded-2xl"} %}
{% set r = radius_map.get(radius, "rounded-xl") %}

{% set density_map = {
  "compact":  {"p": "p-3", "td": "px-4 py-2", "th": "px-4 py-2", "text": "text-xs", "gap_section": "mb-8"},
  "normal":   {"p": "p-4", "td": "px-5 py-3", "th": "px-5 py-3", "text": "text-sm", "gap_section": "mb-12"},
  "spacious": {"p": "p-6", "td": "px-6 py-4", "th": "px-6 py-4", "text": "text-base", "gap_section": "mb-16"},
} %}
{% set d = density_map.get(density, density_map["normal"]) %}

<div class="{{ d.p }} max-w-full">
    {% if page.type == 'activity' %}<h2 class="text-2xl font-bold mb-6 text-gray-800">{{ page.activity_name }}</h2>{% endif %}

    {%- for section_component in page.section_components %}
    <div class="{{ d.gap_section }}">

        {% if page.type != 'activity' %}
        <h2 class="text-xl font-semibold text-gray-800 mb-1">{{ section_component.display_name }}</h2>
        {% endif %}

        {% if page.type == 'activity' %}
        <p class="text-gray-600 mb-4">{{ loop.index }}. {{ section_component.text }}</p>
        {% else %}
        <p class="text-gray-500 mb-4 {{ d.text }}">{{ section_component.text }}</p>
        {% endif %}

        <div class="w-full overflow-x-auto {{ r }} border border-gray-200">
            <table class="w-full border-collapse bg-white">
                <thead>
                    <tr class="{{ c.th_bg }} text-white">
                        {%- for attribute in section_component.attributes %}
                        <th class="{{ d.th }} {{ d.text }} font-semibold uppercase tracking-wide text-left">{{ attribute }}</th>
                        {%- endfor %}
                        {%- for parent_model in section_component.parent_models %}
                        <th class="{{ d.th }} {{ d.text }} font-semibold uppercase tracking-wide text-left">{{ parent_model }}</th>
                        {%- endfor %}
                        {% if section_component.has_update_operation or section_component.has_delete_operation or section_component.custom_methods %}
                        <th class="{{ d.th }} {{ d.text }} font-semibold uppercase tracking-wide text-right">Actions</th>
                        {% endif %}
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-100">

                    {#- DATA ROWS #}
                    {% raw %}{%{% endraw %} for {{ section_component.primary_model }} in {{ section_component.primary_model }}_list {% raw %}%}{% endraw %}

                    {#- UPDATE FORM ROW #}
                    {% if section_component.has_update_operation -%}
                    {% raw %}{%{% endraw %} if {{ section_component.primary_model }} == update_instance {% raw %}%}{% endraw %}
                    <tr class="{{ c.light }}">
                        <form action="{% raw %}{%{% endraw %} url '{{ application_name }}:render_{{ application_name }}_{{ page }}' {% if page.type == 'activity' %}active_process_node_id{% endif %}{% raw %}%}{% endraw %}" method="post">
                            {% raw %}{% csrf_token %}{% endraw %}
                            {% for attribute in section_component.attributes %}
                            {% if attribute.updatable and not attribute.derived %}
                            <td class="{{ d.td }}">
                                {% if attribute.type == AttributeType.STRING %}
                                <input type="text" name="{{ attribute }}" id="{{ attribute }}" value="{% raw %}{{{% endraw %} update_instance.{{ attribute }} {% raw %}}}{% endraw %}" class="w-full border border-gray-300 rounded px-2 py-1 {{ d.text }} {{ c.ring }} focus:outline-none focus:ring-2">
                                {%- elif attribute.type == AttributeType.INTEGER %}
                                <input type="number" name="{{ attribute }}" id="{{ attribute }}" value="{% raw %}{{{% endraw %} update_instance.{{ attribute }} {% raw %}}}{% endraw %}" class="w-full border border-gray-300 rounded px-2 py-1 {{ d.text }} {{ c.ring }} focus:outline-none focus:ring-2">
                                {%- elif attribute.type == AttributeType.BOOLEAN %}
                                <input type="checkbox" name="{{ attribute }}" id="{{ attribute }}" {% raw %}{%{% endraw %} if update_instance.{{ attribute }} {% raw %}%}checked{% endif %}{% endraw %} class="h-4 w-4 rounded">
                                {%- elif attribute.type == AttributeType.ENUM %}
                                <select name="{{ attribute }}" id="{{ attribute }}" class="w-full border border-gray-300 rounded px-2 py-1 {{ d.text }} {{ c.ring }} focus:outline-none focus:ring-2">
                                    {% for literal in attribute.enum_literals %}
                                    <option value="{{ literal }}">{{ literal }}</option>
                                    {% endfor %}
                                </select>
                                {%- endif %}
                            </td>
                            {% else %}
                            <td class="{{ d.td }}">
                                {% if attribute.type == AttributeType.BOOLEAN %}
                                <input type="checkbox" {% raw %}{%{% endraw %} if update_instance.{{ attribute }} {% raw %}%}checked{% endif %}{% endraw %} disabled class="h-4 w-4 rounded">
                                {% else %}
                                <span class="{{ d.text }} text-gray-700">{% raw %}{{{% endraw %} update_instance.{{ attribute }} {% raw %}}}{% endraw %}</span>
                                {% endif %}
                            </td>
                            {% endif %}
                            {% endfor %}
                            {% for parent_model in section_component.parent_models %}
                            <td class="{{ d.td }}">
                                <select name="{{ parent_model }}" class="w-full border border-gray-300 rounded px-2 py-1 {{ d.text }} {{ c.ring }} focus:outline-none focus:ring-2">
                                    {% raw %}{%{% endraw %} for i in parent_{{ parent_model }}_list {% raw %}%}{% endraw %}
                                    {% raw %}<option value="{{ i.id }}">{{ i }}</option>{% endraw %}
                                    {% raw %}{% endfor %}{% endraw %}
                                </select>
                            </td>
                            {% endfor %}
                            <td class="{{ d.td }} text-right">
                                <div class="flex gap-2 justify-end">
                                    <input type="submit" value="Save" class="{{ c.btn }} text-white {{ d.text }} font-medium py-1.5 px-3 rounded cursor-pointer">
                                    <a href="{% raw %}{%{% endraw %} url '{{ application_name }}:render_{{ application_name }}_{{ page }}' {% if page.type == 'activity' %}active_process_node_id{% endif %} {% raw %}%}{% endraw %}" class="bg-gray-100 text-gray-600 {{ d.text }} font-medium py-1.5 px-3 rounded hover:bg-gray-200">Cancel</a>
                                </div>
                            </td>
                        </form>
                    </tr>
                    {% raw %}{% else %}{% endraw %}
                    {% endif -%}

                    {#- DISPLAY ROW (inside Django else) #}
                    <tr class="hover:bg-gray-50 transition-colors">
                        {% for attribute in section_component.attributes -%}
                        <td class="{{ d.td }}">
                            {% if attribute.type == AttributeType.BOOLEAN -%}
                            <input type="checkbox" {% raw %}{%{% endraw %} if {{ section_component.primary_model }}.{{ attribute }} {% raw %}%}checked{% endif %}{% endraw %} disabled class="h-4 w-4 rounded">
                            {%- else %}
                            <span class="{{ d.text }} text-gray-800">{% raw %}{{{% endraw %} {{ section_component.primary_model }}.{{ attribute }} {% raw %}}}{% endraw %}</span>
                            {% endif -%}
                        </td>
                        {% endfor -%}
                        {% for parent_model in section_component.parent_models -%}
                        <td class="{{ d.td }}">
                            <span class="{{ d.text }} text-gray-800">{% raw %}{{{% endraw %} {{ section_component.primary_model }}.{{ parent_model }} {% raw %}}}{% endraw %}</span>
                        </td>
                        {% endfor -%}

                        {#- ACTION CELL #}
                        {% if section_component.has_update_operation or section_component.has_delete_operation or section_component.custom_methods %}
                        <td class="{{ d.td }} text-right">
                            <div class="flex gap-2 justify-end">
                                {%- if section_component.has_update_operation %}
                                {% raw %}{%{% endraw %} if {{ section_component.primary_model }} != update_instance {% raw %}%}{% endraw %}
                                <form action="{% raw %}{%{% endraw %} url '{{ application_name }}:render_{{ application_name }}_{{ page }}' {% if page.type == 'activity' %}active_process_node_id{% endif %}{% raw %}%}{% endraw %}" method="get">
                                    <input type="hidden" name="instance_id_{{ section_component.primary_model }}" value="{{ '{{' }}{{ section_component.primary_model }}.id{{ '}}' }}">
                                    <button type="submit" class="{{ d.text }} {{ c.text }} hover:opacity-70 font-medium py-1 px-3 rounded hover:{{ c.light }} transition-colors">Edit</button>
                                </form>
                                {% raw %}{% endif %}{% endraw %}
                                {% endif -%}

                                {%- if section_component.has_delete_operation %}
                                <form action="{% raw %}{%{% endraw %} url '{{ application_name }}:{{ page }}_{{ section_component }}_delete' {% if page.type == 'activity' %}active_process_node_id{% endif %} {{ section_component.primary_model }}.id {% raw %}%}{% endraw %}" method="post">
                                    {% raw %}{% csrf_token %}{% endraw %}
                                    <button type="submit" class="{{ d.text }} text-red-500 hover:text-red-700 font-medium py-1 px-3 rounded hover:bg-red-50 transition-colors">Delete</button>
                                </form>
                                {% endif -%}

                                {%- for custom_method in section_component.custom_methods %}
                                <form action="{% raw %}{%{% endraw %} url '{{ application_name }}:render_{{ application_name }}_{{ page }}' {% if page.type == 'activity' %}active_process_node_id{% endif %} {% raw %}%}{% endraw %}" method="get">
                                    <input type="hidden" name="custom_{{ section_component.primary_model }}_{{ custom_method }}" value="{{ '{{' }}{{ section_component.primary_model }}.id{{ '}}' }}">
                                    <button type="submit" class="{{ d.text }} text-gray-600 font-medium py-1 px-3 rounded border border-gray-200 hover:bg-gray-50 transition-colors">{{ custom_method }}</button>
                                </form>
                                {% endfor -%}
                            </div>
                        </td>
                        {% endif %}
                    </tr>

                    {%- if section_component.has_update_operation %}
                    {% raw %}{% endif %}{% endraw %}
                    {% endif -%}

                    {% raw %}{% endfor %}{% endraw %}

                    {#- CREATE FORM ROW #}
                    {%- if section_component.has_create_operation %}
                    {% raw %}{%{% endraw %} if create_{{ section_component }} {% raw %}%}{% endraw %}
                    <tr class="{{ c.light }} border-t-2 {{ c.border }}">
                        <form action="{% raw %}{%{% endraw %} url '{{ application_name }}:{{ page }}_{{ section_component }}_create' {% if page.type == 'activity' %}active_process_node_id{% endif %} {% raw %}%}{% endraw %}" method="post">
                            {% raw %}{% csrf_token %}{% endraw %}
                            {% for attribute in section_component.attributes -%}
                            {% if attribute.derived -%}
                            <td class="{{ d.td }}"></td>
                            {% else -%}
                            <td class="{{ d.td }}">
                                {% if attribute.type == AttributeType.STRING -%}
                                <input type="text" name="{{ attribute }}" placeholder="{{ attribute }}" class="w-full border {{ c.border }} bg-white rounded px-2 py-1 {{ d.text }} {{ c.ring }} focus:outline-none focus:ring-2">
                                {% elif attribute.type == AttributeType.INTEGER -%}
                                <input type="number" name="{{ attribute }}" placeholder="{{ attribute }}" class="w-full border {{ c.border }} bg-white rounded px-2 py-1 {{ d.text }} {{ c.ring }} focus:outline-none focus:ring-2">
                                {% elif attribute.type == AttributeType.BOOLEAN -%}
                                <input type="checkbox" name="{{ attribute }}" class="h-4 w-4 rounded">
                                {% elif attribute.type == AttributeType.ENUM -%}
                                <select name="{{ attribute }}" class="w-full border {{ c.border }} bg-white rounded px-2 py-1 {{ d.text }} {{ c.ring }} focus:outline-none focus:ring-2">
                                    {% for literal in attribute.enum_literals %}
                                    <option value="{{ literal }}">{{ literal }}</option>
                                    {% endfor %}
                                </select>
                                {%- endif %}
                            </td>
                            {% endif -%}
                            {% endfor -%}
                            {% for parent_model in section_component.parent_models -%}
                            <td class="{{ d.td }}">
                                <select name="{{ parent_model }}" class="w-full border {{ c.border }} bg-white rounded px-2 py-1 {{ d.text }} {{ c.ring }} focus:outline-none focus:ring-2">
                                    {% raw %}{%{% endraw %} for i in parent_{{ parent_model }}_list {% raw %}%}{% endraw %}
                                    {% raw %}<option value="{{ i.id }}">{{ i }}</option>{% endraw %}
                                    {% raw %}{% endfor %}{% endraw %}
                                </select>
                            </td>
                            {% endfor -%}
                            <td class="{{ d.td }} text-right">
                                <div class="flex gap-2 justify-end">
                                    <input type="submit" value="Save" class="{{ c.btn }} text-white {{ d.text }} font-medium py-1.5 px-3 rounded cursor-pointer">
                                    <a href="{% raw %}{%{% endraw %} url '{{ application_name }}:render_{{ application_name }}_{{ page }}' {% if page.type == 'activity' %}active_process_node_id{% endif %} {% raw %}%}{% endraw %}" class="bg-white text-gray-600 {{ d.text }} font-medium py-1.5 px-3 rounded border border-gray-200 hover:bg-gray-50">Cancel</a>
                                </div>
                            </td>
                        </form>
                    </tr>
                    {% raw %}{% endif %}{% endraw %}
                    {% endif -%}

                </tbody>
            </table>
        </div>

        {#- CREATE BUTTON #}
        {%- if section_component.has_create_operation %}
        {% raw %}{%{% endraw %} if not create_{{ section_component }} {% raw %}%}{% endraw %}
        <form action="{% raw %}{%{% endraw %} url '{{ application_name }}:render_{{ application_name }}_{{ page }}' {% if page.type == 'activity' %}active_process_node_id{% endif %} {% raw %}%}{% endraw %}" method="get" class="mt-3">
            <input type="hidden" name="create_{{ section_component }}" value="true">
            <button type="submit" class="flex items-center gap-2 {{ d.text }} font-medium {{ c.text }} py-2 px-4 {{ r }} border {{ c.border }} hover:{{ c.light }} transition-colors">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M12 5v14M5 12h14"/></svg>
                Add {{ section_component.display_name }}
            </button>
        </form>
        {% raw %}{% endif %}{% endraw %}
        {%- endif %}

    </div>
    {% endfor %}

    {% if page.type == 'activity' %}
    <div class="fixed bottom-6 right-6">
        <form action="{% raw %}{%{% endraw %} url 'workflow_engine:complete_process_step' active_process_node_id {% raw %}%}{% endraw %}" method="post">
            {% raw %}{% csrf_token %}{% endraw %}
            <button type="submit" class="bg-green-600 text-white font-semibold py-3 px-6 {{ r }} shadow-lg hover:bg-green-700 transition-colors">Complete task</button>
        </form>
    </div>
    {% endif %}
</div>

{% raw %}{% endblock %}{% endraw %}
