{%- set _tokens = theme.get('tokens', {}) if theme else {} -%}
{%- set _has_tokens = _tokens | length > 0 -%}
.process-container {
    display: flex;
    justify-content: flex-start;
    align-items: flex-start;
    gap: 20px;
    margin-top: 20px;
}

.available-processes {
    flex: 1;
    max-width: 48%;
    text-align: left;
}

.active-processes {
    flex: 1;
    max-width: 48%;
    text-align: left;
}

.filter-form {
    margin-bottom: 20px;
}

.filter-form label {
    margin-right: 10px;
}

.filter-form input,
.filter-form select {
    margin-right: 10px;
}

.trashcan {
  width: 20px;
  height: 20px;
  
  .trashcan-open {
    display: none;
  }
  
  &:hover {
    .trashcan-open {
      display: inline;
    }
    .trashcan-closed {
      display: none;
    }
  }
  
}

/* ── Layout-specific styles ───────────────────────────── */

/* ── Breadcrumbs ── */
.breadcrumbs {
    display: flex;
    align-items: center;
    gap: 4px;
    padding: 8px 0;
    margin-bottom: 16px;
    font-size: 13px;
    color: #666;
}
.breadcrumbs a {
    text-decoration: none;
    color: {{ styling.accent_color }};
}
.breadcrumbs a:hover {
    text-decoration: underline;
}
.breadcrumb-sep {
    margin: 0 4px;
    color: #999;
}
.breadcrumb-current {
    font-weight: 600;
    color: {{ styling.text_color }};
}

/* ── Tabs ── */
.tabs {
    display: flex;
    gap: 2px;
    border-bottom: 2px solid #e0e0e0;
    margin-bottom: 0;
}
.tab-btn {
    padding: 10px 20px;
    border: none;
    background: transparent;
    cursor: pointer;
    font-size: 14px;
    font-weight: 500;
    color: #666;
    border-bottom: 2px solid transparent;
    margin-bottom: -2px;
    transition: color 0.2s, border-color 0.2s;
}
.tab-btn:hover {
    color: {{ styling.text_color }};
}
.tab-btn.tab-active {
    color: {{ styling.text_color }};
    border-bottom-color: {{ styling.accent_color }};
    font-weight: 600;
}
.tab-panel {
    display: none;
    padding-top: 16px;
}
.tab-panel-active {
    display: block;
}

/* ── Search Bar ── */
.search-bar {
    position: relative;
    margin-bottom: 12px;
    max-width: 320px;
}
.search-input {
    width: 100%;
    padding: 8px 12px;
    border: 1px solid #ddd;
    border-radius: {{ styling.radius }}px;
    font-size: 14px;
    box-sizing: border-box;
}
.search-input:focus {
    outline: none;
    border-color: {{ styling.accent_color }};
    box-shadow: 0 0 0 2px rgba(0,0,0,0.05);
}

/* ── Pagination ── */
.pagination {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-top: 12px;
    font-size: 13px;
}
.page-btn {
    padding: 6px 14px;
    border: 1px solid #ddd;
    background: {{ styling.background_color }};
    border-radius: {{ styling.radius }}px;
    cursor: pointer;
    font-size: 13px;
    transition: background 0.2s;
}
.page-btn:hover:not(:disabled) {
    background: {{ styling.accent_color }};
}
.page-btn:disabled {
    opacity: 0.4;
    cursor: default;
}
.page-info {
    color: #666;
}

/* ── Section Header / Accordion ── */
.section-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    cursor: pointer;
    padding: 8px 0;
    user-select: none;
}
.section-header:hover {
    opacity: 0.8;
}
.accordion-icon {
    font-size: 12px;
    color: #999;
    transition: transform 0.2s;
}
.section-body {
    transition: max-height 0.3s ease;
    overflow: visible;
}
.section-body-collapsed {
    max-height: 0 !important;
    overflow: hidden;
    padding: 0;
    margin: 0;
}

/* ── Modal ── */
.modal-overlay {
    display: none;
    position: fixed;
    top: 0; left: 0; right: 0; bottom: 0;
    background: rgba(0,0,0,0.4);
    z-index: 1000;
    justify-content: center;
    align-items: center;
}
.modal-overlay.modal-visible {
    display: flex;
}
.modal {
    background: {{ styling.background_color }};
    border-radius: {{ styling.radius }}px;
    width: 90%;
    max-width: 520px;
    max-height: 85vh;
    overflow-y: auto;
    box-shadow: 0 8px 32px rgba(0,0,0,0.2);
}
.modal-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 16px 20px;
    border-bottom: 1px solid #e0e0e0;
}
.modal-header h3 {
    margin: 0;
    font-size: 18px;
}
.modal-close {
    background: none;
    border: none;
    font-size: 24px;
    cursor: pointer;
    color: #666;
    padding: 0;
    line-height: 1;
}
.modal-close:hover {
    color: {{ styling.text_color }};
}
.modal-body {
    padding: 20px;
}

/* ── Form Group ── */
.form-group {
    margin-bottom: 16px;
}
.form-group label {
    display: block;
    margin-bottom: 4px;
    font-weight: 500;
    font-size: 14px;
    text-transform: capitalize;
}
.form-group input[type="text"],
.form-group input[type="number"],
.form-group input[type="email"],
.form-group input[type="date"],
.form-group input[type="datetime-local"],
.form-group select,
.form-group textarea {
    width: 100%;
    padding: 8px 10px;
    border: 1px solid #ccc;
    border-radius: {{ styling.radius }}px;
    font-size: 14px;
    box-sizing: border-box;
}
.form-group textarea {
    resize: vertical;
}
.form-group input[type="checkbox"] {
    width: auto;
}
.modal-actions {
    display: flex;
    gap: 8px;
    justify-content: flex-end;
    margin-top: 20px;
    padding-top: 16px;
    border-top: 1px solid #e0e0e0;
}
.btn-save {
    padding: 8px 20px;
    border: none;
    border-radius: {{ styling.radius }}px;
    cursor: pointer;
    font-size: 14px;
    font-weight: 500;
}
.btn-cancel {
    padding: 8px 20px;
    border: 1px solid #ccc;
    border-radius: {{ styling.radius }}px;
    background: transparent;
    cursor: pointer;
    font-size: 14px;
}

/* ── Create Button ── */
.create-open-btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 8px 16px;
    margin-top: 12px;
    border: 1px solid #ddd;
    border-radius: {{ styling.radius }}px;
    background: {{ styling.background_color }};
    cursor: pointer;
    font-size: 14px;
    transition: background 0.2s;
}
.create-open-btn:hover {
    background: {{ styling.accent_color }};
}

/* ══════════════════════════════════════════ */
/* ██  Dashboard Layout                   ██ */
/* ══════════════════════════════════════════ */
.dashboard-cards {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 16px;
    margin-bottom: 24px;
}
.dashboard-card {
    padding: 20px;
    border-radius: {{ styling.radius }}px;
    border: 1px solid #e0e0e0;
    text-align: center;
}
.dashboard-card-header h3 {
    margin: 0 0 8px;
    font-size: 14px;
    font-weight: 500;
    opacity: 0.7;
}
.dashboard-card-value {
    font-size: 36px;
    font-weight: 700;
    line-height: 1.2;
}
.dashboard-card-label {
    font-size: 12px;
    opacity: 0.5;
    margin-top: 4px;
}
.dashboard-section {
    margin-bottom: 24px;
    padding: 16px;
    border-radius: {{ styling.radius }}px;
    border: 1px solid #e0e0e0;
}
.dashboard-section-header h3 {
    margin: 0 0 12px;
    font-size: 16px;
    font-weight: 600;
}

/* ══════════════════════════════════════════ */
/* ██  Standalone Form Layout             ██ */
/* ══════════════════════════════════════════ */
.standalone-form-container {
    max-width: 640px;
    margin: 0 auto;
    padding: 24px;
    border-radius: {{ styling.radius }}px;
    border: 1px solid #e0e0e0;
}
.standalone-form-container h2 {
    margin: 0 0 16px;
}
.standalone-form .form-group {
    margin-bottom: 16px;
}
.form-actions {
    display: flex;
    gap: 12px;
    justify-content: flex-end;
    margin-top: 24px;
    padding-top: 16px;
    border-top: 1px solid #e0e0e0;
}

/* ══════════════════════════════════════════ */
/* ██  Modal Page Layout (centered card)  ██ */
/* ══════════════════════════════════════════ */
.modal-page-wrapper {
    display: flex;
    justify-content: center;
    align-items: flex-start;
    min-height: 60vh;
    padding: 40px 16px;
}
.modal-page-card {
    width: 100%;
    max-width: 500px;
    padding: 28px;
    border-radius: {{ styling.radius }}px;
    border: 1px solid #e0e0e0;
    box-shadow: 0 4px 24px rgba(0,0,0,0.08);
}
.modal-page-card h2 {
    margin: 0 0 16px;
}

/* ══════════════════════════════════════════ */
/* ██  Wizard Layout                      ██ */
/* ══════════════════════════════════════════ */
.wizard-container {
    max-width: 720px;
    margin: 0 auto;
    padding: 24px;
    border-radius: {{ styling.radius }}px;
    border: 1px solid #e0e0e0;
}
.wizard-container > h2 {
    margin: 0 0 20px;
}
.wizard-steps {
    display: flex;
    align-items: center;
    gap: 0;
    margin-bottom: 24px;
    padding: 0 8px;
}
.wizard-step {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 8px 12px;
    border-radius: {{ styling.radius }}px;
    font-size: 14px;
    opacity: 0.5;
    transition: opacity 0.2s;
}
.wizard-step-active {
    opacity: 1;
    font-weight: 600;
}
.wizard-step-done {
    opacity: 0.7;
}
.wizard-step-done .wizard-step-number {
    background: {{ styling.accent_color }};
    color: {{ styling.background_color }};
}
.wizard-step-number {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    border-radius: 50%;
    border: 2px solid currentColor;
    font-size: 13px;
    font-weight: 700;
}
.wizard-step-active .wizard-step-number {
    background: {{ styling.accent_color }};
    color: {{ styling.background_color }};
    border-color: {{ styling.accent_color }};
}
.wizard-step-connector {
    flex: 1;
    height: 2px;
    background: #e0e0e0;
    min-width: 20px;
}
.wizard-panel {
    display: none;
}
.wizard-panel-active {
    display: block;
}
.wizard-panel h3 {
    margin: 0 0 12px;
}
.wizard-form .form-group {
    margin-bottom: 16px;
}
.wizard-nav {
    display: flex;
    justify-content: space-between;
    margin-top: 24px;
    padding-top: 16px;
    border-top: 1px solid #e0e0e0;
}
.wizard-prev, .wizard-next {
    padding: 8px 20px;
    border: 1px solid #ccc;
    border-radius: {{ styling.radius }}px;
    cursor: pointer;
    font-size: 14px;
}
.wizard-prev:disabled {
    opacity: 0.4;
    cursor: not-allowed;
}

/* ══════════════════════════════════════════ */
/* ██  Section Links                      ██ */
/* ══════════════════════════════════════════ */
.section-links {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 12px;
}
.section-link {
    display: inline-block;
    padding: 6px 14px;
    border: 1px solid #ddd;
    border-radius: {{ styling.radius }}px;
    text-decoration: none;
    font-size: 13px;
    transition: background 0.2s;
}
.section-link:hover {
    background: {{ styling.accent_color }};
    color: {{ styling.background_color }};
}

{% if styling.layout_type == LayoutType.TOP_NAV %}
.topnav {
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
    padding: 8px 16px;
    background-color: {{ styling.accent_color }};
    border-bottom: 1px solid rgba(0, 0, 0, 0.1);
}

.topnav a {
    text-decoration: none;
    padding: 8px 14px;
    border-radius: {{ styling.radius }}px;
    font-size: 14px;
    white-space: nowrap;
    transition: background-color 0.2s;
}

.topnav a:hover {
    background-color: {{ styling.background_color }};
}

.content-topnav {
    margin-left: 0 !important;
    padding: 24px;
}

{% elif styling.layout_type == LayoutType.TOP_NAV_SIDEBAR %}
.topnav-inline {
    display: inline-flex;
    gap: 8px;
    margin-left: 24px;
}

.topnav-inline a {
    text-decoration: none;
    padding: 6px 12px;
    border-radius: {{ styling.radius }}px;
    font-size: 13px;
    white-space: nowrap;
    transition: background-color 0.2s;
}

.topnav-inline a:hover {
    background-color: {{ styling.background_color }};
}

.header {
    display: flex;
    align-items: center;
}

{% elif styling.layout_type == LayoutType.SIDEBAR_RIGHT %}
.menu-right {
    float: right !important;
    border-left: 1px solid rgba(0, 0, 0, 0.1);
    border-right: none;
}

.content-sidebar-right {
    margin-left: 0 !important;
    margin-right: 240px;
}

{% endif %}

