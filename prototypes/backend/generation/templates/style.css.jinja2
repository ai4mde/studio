/* ========== COMMON STYLES ========== */
/* Base reset and shared styles that work with Tailwind */
* { margin: 0; padding: 0; box-sizing: border-box; }

/* Tables - consistent across all layouts */
table { width: 100%; border-collapse: collapse; }
th {
    text-align: left;
    padding: 12px 10px;
    background: #f9fafb;
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    color: #64748b;
    border-bottom: 1px solid #e5e7eb;
}
td {
    padding: 12px 10px;
    border-bottom: 1px solid #e5e7eb;
    font-size: 13px;
}
tr:hover td { background: #f9fafb; }

/* Form elements */
input, select, textarea {
    padding: 8px 12px;
    border: 1px solid #e5e7eb;
    border-radius: {{ styling.radius }}px;
    font-size: 13px;
    background: #fff;
}
input:focus, select:focus, textarea:focus {
    outline: none;
    border-color: {{ styling.accent_color }};
    box-shadow: 0 0 0 3px {{ styling.accent_color }}22;
}

/* Buttons */
input[type="submit"], button.btn, .btn {
    padding: 8px 16px;
    background: {{ styling.accent_color }};
    color: #fff;
    border: none;
    border-radius: {{ styling.radius }}px;
    cursor: pointer;
    font-size: 13px;
    transition: opacity 0.2s;
}
input[type="submit"]:hover, button.btn:hover, .btn:hover {
    opacity: 0.9;
}
.btn-secondary, .btn-outline {
    background: transparent;
    border: 1px solid {{ styling.accent_color }};
    color: {{ styling.accent_color }};
}

/* Badges */
.badge {
    display: inline-block;
    padding: 3px 8px;
    border-radius: 14px;
    font-size: 10px;
    font-weight: 600;
    background: #f3f4f6;
    color: #374151;
}
.b-c, .b-s { background: #dcfce7; color: #16a34a; }
.b-u, .b-i { background: #dbeafe; color: #2563eb; }
.b-d, .b-w { background: #fee2e2; color: #dc2626; }

/* Django form error messages */
.errorlist {
    color: #dc2626;
    font-size: 12px;
    list-style: none;
    padding: 0;
    margin: 4px 0;
}

/* Form field layout */
.form-group, .field {
    margin-bottom: 16px;
}
.form-group label, .field label {
    display: block;
    font-size: 12px;
    font-weight: 600;
    margin-bottom: 6px;
    color: #374151;
}
.form-group input, .form-group select, .form-group textarea,
.field input, .field select, .field textarea {
    width: 100%;
}

/* Links styling */
a {
    color: {{ styling.accent_color }};
    text-decoration: none;
}
a:hover {
    text-decoration: underline;
}

{% if styling.custom_css %}
/* ========== DESIGNER CUSTOM CSS ========== */
{{ styling.custom_css }}
{% endif %}
