{% else %}
{# ─── No Tailwind tokens — use theme_summary / styling CSS custom properties ── #}

:root {
    --theme-body-bg: {{ theme_summary.background_color or styling.background_color }};
    --theme-body-text: {{ theme_summary.text_color or styling.text_color }};
    --theme-surface-bg: {{ theme_summary.surface_color or styling.background_color }};
    --theme-surface-text: {{ theme_summary.surface_text_color or theme_summary.text_color or styling.text_color }};
    --theme-border-color: {{ theme_summary.border_color or theme_summary.accent_color or styling.accent_color }};
    --theme-accent-bg: {{ theme_summary.accent_color or styling.accent_color }};
    --theme-accent-text: {{ theme_summary.button_text_color or styling.text_color }};
    --theme-input-bg: {{ theme_summary.input_background_color or theme_summary.surface_color or styling.background_color }};
    --theme-input-text: {{ theme_summary.input_text_color or theme_summary.text_color or styling.text_color }};
    --theme-input-border: {{ theme_summary.input_border_color or theme_summary.border_color or styling.accent_color }};
    --theme-radius: {{ theme_summary.radius or styling.radius }}px;
    --theme-button-radius: {{ theme_summary.button_radius or theme_summary.radius or styling.radius }}px;
    --theme-input-radius: {{ theme_summary.input_radius or theme_summary.radius or styling.radius }}px;
    --theme-surface-shadow: {{ theme_summary.surface_shadow or '0px 4px 8px rgba(0, 0, 0, 0.1)' }};
    --theme-font-family: {{ theme_summary.font_family or 'inherit' }};
}

body {
    background-color: var(--theme-body-bg) !important;
    color: var(--theme-body-text) !important;
    font-family: var(--theme-font-family), sans-serif;
}

.header,
.menu,
th,
input[type="submit"],
.process-button,
.complete-activity-button {
    background-color: var(--theme-accent-bg) !important;
    color: var(--theme-accent-text) !important;
    border-radius: var(--theme-button-radius) !important;
}

.content,
.process-item,
table,
table td {
    background-color: var(--theme-surface-bg) !important;
    color: var(--theme-surface-text) !important;
    border-radius: var(--theme-radius) !important;
    box-shadow: var(--theme-surface-shadow);
}

.header,
.menu,
.content,
table,
table th,
table td,
.process-item,
.complete-activity-button,
input[type="submit"] {
    border-color: var(--theme-border-color) !important;
}

.menu a {
    color: var(--theme-accent-text) !important;
    border-radius: var(--theme-button-radius) !important;
}

.menu a:hover,
.process-button:hover,
.complete-activity-button:hover,
input[type="submit"]:hover {
    filter: brightness(0.95);
}

td input[type="text"],
td input[type="number"],
td select,
td textarea,
select,
input[type="text"],
input[type="number"] {
    background-color: var(--theme-input-bg) !important;
    color: var(--theme-input-text) !important;
    border: 1px solid var(--theme-input-border) !important;
    border-radius: var(--theme-input-radius) !important;
}

{% endif %}