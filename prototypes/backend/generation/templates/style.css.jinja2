    justify-content: space-between;
    align-items: center;
    position: relative;
}

.process-item:hover {
    transform: translateY(-5px);
    box-shadow: 0px 6px 12px rgba(0, 0, 0, 0.2);
}

.process-item h4 {
    margin: 0;
    padding: 0;
    font-size: 20px;
    color: {{ styling.text_color }};
    flex: 1;
    text-align: left;
    line-height: 1;
}

.process-button {
    background-color: {{ styling.accent_color }};
    color: {{ styling.text_color }};
    border: none;
    padding: 12px;
    border-radius: {{ styling.radius }}px;
    cursor: pointer;
    transition: background-color 0.3s, transform 0.3s;
    flex-shrink: 0;
}

.process-button:hover {
    background-color: {{ styling.text_color }};
    color: {{ styling.background_color }};
    transform: scale(1.05);
}

.no-processes {
    font-size: 18px;
    color: {{ styling.text_color }};
    text-align: left;
}

.active-node-name {
    font-size: 14px;
    color: {{ styling.text_color}};
    margin-top: 5px;
    text-align: left;
}

table {
    width: 100%;
    border-collapse: collapse;
    margin-top: 20px;
    border-radius: {{ styling.radius }}px;
    overflow: hidden;
}

table th, table td {
    border: 1px solid #ddd;
    padding: 8px;
    text-align: left;
}

table th {
    background-color: {{ styling.background_color }};
    font-size: 18px;
    text-align: center;
    padding: 12px;
}

table td {
    text-align: left;
}

.complete-activity-button {
    padding: 10px 20px;
    background-color: {{ styling.background_color }};
    color: {{ styling.text_color }};
    border: 2px solid {{ styling.text_color }};
    border-radius: {{ styling.radius }}px;
    cursor: pointer;
    font-size: 16px;
}

.complete-activity-button:hover {
    background-color: {{ styling.text_color }};
    color: {{ styling.background_color }};
}


