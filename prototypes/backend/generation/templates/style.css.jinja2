}

table {
    width: 100%;
    border-collapse: collapse;
    margin-top: 20px;
    border-radius: {{ styling.radius }}px;
    overflow: hidden;
}

th, td {
    padding: 0;
    text-align: left;
}

th {
    background-color: {{ styling.accent_color }};
    font-size: 18px;
    text-align: center;
    padding: 12px;
}

