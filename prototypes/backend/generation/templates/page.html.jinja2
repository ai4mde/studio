{% raw %}{%{% endraw %} extends "{{ application_name }}_base.html" {% raw %}%}{% endraw %}
{%- set tokens = theme.get('tokens', {}) if theme else {} -%}
{%- set has_theme = tokens | length > 0 -%}

{#- ── BREADCRUMBS ── #}
{% raw %}{% block breadcrumbs %}{% endraw %}
{% if page.category %}<span class="breadcrumb-sep">/</span><span>{{ page.category }}</span>{% endif %}
<span class="breadcrumb-sep">/</span><span class="breadcrumb-current">{{ page.display_name }}</span>
{% raw %}{% endblock %}{% endraw %}

{% raw %}{% block content %}{% endraw %}


<div{% if has_theme %} class="{{ tokens.get('page.surface', '') }}"{% endif %}>
    {% if page.type == 'activity' %}<h2>{{ page.activity_name}}</h2>{% endif %}

    {#- ── TABS (when multiple sections) ── #}
    {% if page.section_components | length > 1 and page.type != 'activity' %}
    <div class="tabs" role="tablist">
        {% for section_component in page.section_components %}
        <button class="tab-btn{% if loop.first %} tab-active{% endif %}"
                role="tab"
                aria-selected="{% if loop.first %}true{% else %}false{% endif %}"
                data-tab="tab-{{ loop.index }}">
            {{ section_component.display_name }}
        </button>
        {% endfor %}
    </div>
    {% endif %}

    {%- for section_component in page.section_components %}

    {#- ── TAB PANEL WRAPPER ── #}
    {% if page.section_components | length > 1 and page.type != 'activity' %}
    <div class="tab-panel{% if loop.first %} tab-panel-active{% endif %}" id="tab-{{ loop.index }}" role="tabpanel">
    {% endif %}

    {#- ── SECTION HEADER (with accordion toggle) ── #}
    {% if page.type != 'activity' %}
    <div class="section-header" data-accordion="section-body-{{ loop.index }}">
        <h2{% if has_theme %} class="{{ tokens.get('element.heading', '') }}"{% endif %}>{{ section_component.display_name }}</h2>
        <span class="accordion-icon">&#9660;</span>
    </div>
    {% else %}
        <p>{{ loop.index }}. {{ section_component.text}}</p>
    {% endif %}

    <div class="section-body{% if has_theme %} {{ tokens.get('component.card', '') }}{% endif %}" id="section-body-{{ loop.index }}">
    {% if page.type != 'activity' and section_component.text %}
    <p>{{ section_component.text}}</p>
    {% endif %}

    {#- ── SEARCH BAR ── #}
    <div class="search-bar">
        <input type="text" class="search-input" placeholder="Search..." data-table="table-{{ loop.index }}">
    </div>

    {# TABLE WITH OBJECTS, UPDATE BUTTONS, DELETE BUTTONS -#}
    <table id="table-{{ loop.index }}"{% if has_theme %} class="{{ tokens.get('component.table', '') }}"{% endif %}>

        {#- COLUMN HEADERS #}
        <thead>
        <tr>
            {%- for attribute in section_component.attributes %}
            <th{% if has_theme %} class="{{ tokens.get('element.th', '') }}"{% endif %}>{{ attribute }}</th>
            {%- endfor %}
            {%- for parent_model in section_component.parent_models %}
            <th{% if has_theme %} class="{{ tokens.get('element.th', '') }}"{% endif %}>{{ parent_model }}</th>
            {%- endfor %}
        </tr>
        </thead>

        <tbody>
        {#- ROWS #}
        {% raw %}{%{% endraw %} for {{ section_component.primary_model }} in {{ section_component.primary_model }}_list {% raw %}%}{% endraw %}
        <tr>
            {#- UPDATE FORM #}
            {% if section_component.has_update_operation -%}
            {% raw %}{%{% endraw %} if {{ section_component.primary_model }} == update_instance {% raw %}%}{% endraw %}
            <form action="{% raw %}{%{% endraw %} url '{{ application_name }}:{{ page }}_{{ section_component }}_update' {% if page.type == 'activity' %}active_process_node_id{% endif %} update_instance.id{% raw %}%}{% endraw %}" method="post">
                {% raw %}{% csrf_token %}{% endraw %}
                {% for attribute in section_component.attributes %}
                {% if attribute.updatable and not attribute.derived %}
                <td{% if has_theme %} class="{{ tokens.get('element.td', '') }}"{% endif %} style="text-align:center;">
                    {% if attribute.type == AttributeType.STRING %}
                    <input type="text" name="{{ attribute }}" id="{{ attribute }}" value="{% raw %}{{{% endraw %} update_instance.{{ attribute }} {% raw %}}}{% endraw %}"{% if has_theme %} class="{{ tokens.get('element.input.editable', '') }}"{% endif %}>
                    
                    {%- elif attribute.type == AttributeType.INTEGER %}
                    <input type="number" name="{{ attribute }}" id="{{ attribute }}" value="{% raw %}{{{% endraw %} update_instance.{{ attribute }} {% raw %}}}{% endraw %}"{% if has_theme %} class="{{ tokens.get('element.input.editable', '') }}"{% endif %}>

                    {%- elif attribute.type == AttributeType.FLOAT %}
                    <input type="number" step="0.01" name="{{ attribute }}" id="{{ attribute }}" value="{% raw %}{{{% endraw %} update_instance.{{ attribute }} {% raw %}}}{% endraw %}"{% if has_theme %} class="{{ tokens.get('element.input.editable', '') }}"{% endif %}>
                    
                    {%- elif attribute.type == AttributeType.BOOLEAN %}
                    <input type="checkbox" name="{{ attribute }}" id="{{ attribute }}" {% raw %}{%{% endraw %} if update_instance.{{ attribute }} {% raw %}%}checked{% endif %}{% endraw %}{% if has_theme %} class="{{ tokens.get('element.input.editable', '') }}"{% endif %}>
                    
                    {%- elif attribute.type == AttributeType.ENUM %}
                    <select name="{{ attribute }}" id="{{ attribute }}"{% if has_theme %} class="{{ tokens.get('element.input.editable', '') }}"{% endif %}>
                        {% for literal in attribute.enum_literals %}
                            <option value="{{ literal }}">{{ literal }}</option>
                        {% endfor %}
                    </select>

                    {%- elif attribute.type == AttributeType.DATE %}
                    <input type="date" name="{{ attribute }}" id="{{ attribute }}" value="{% raw %}{{{% endraw %} update_instance.{{ attribute }}|date:'Y-m-d' {% raw %}}}{% endraw %}"{% if has_theme %} class="{{ tokens.get('element.input.editable', '') }}"{% endif %}>

                    {%- elif attribute.type == AttributeType.DATETIME %}
                    <input type="datetime-local" name="{{ attribute }}" id="{{ attribute }}" value="{% raw %}{{{% endraw %} update_instance.{{ attribute }}|date:'Y-m-d\TH:i' {% raw %}}}{% endraw %}"{% if has_theme %} class="{{ tokens.get('element.input.editable', '') }}"{% endif %}>

                    {%- elif attribute.type == AttributeType.TEXT %}
                    <textarea name="{{ attribute }}" id="{{ attribute }}" rows="3"{% if has_theme %} class="{{ tokens.get('element.input.editable', '') }}"{% endif %}>{% raw %}{{{% endraw %} update_instance.{{ attribute }} {% raw %}}}{% endraw %}</textarea>

                    {%- elif attribute.type == AttributeType.EMAIL %}
                    <input type="email" name="{{ attribute }}" id="{{ attribute }}" value="{% raw %}{{{% endraw %} update_instance.{{ attribute }} {% raw %}}}{% endraw %}"{% if has_theme %} class="{{ tokens.get('element.input.editable', '') }}"{% endif %}>
                    {%- endif %}
                </td>

                {% else %}
                {% if attribute.type in [AttributeType.STRING, AttributeType.INTEGER, AttributeType.FLOAT, AttributeType.ENUM, AttributeType.EMAIL, AttributeType.TEXT] %}
                <td{% if has_theme %} class="{{ tokens.get('element.td', '') }}"{% endif %} style="text-align:center;">{% raw %}{{{% endraw %} {{ section_component.primary_model }}.{{ attribute }} {% raw %}}}{% endraw %}</td>
                
                {% elif attribute.type == AttributeType.BOOLEAN %}
                <td{% if has_theme %} class="{{ tokens.get('element.td', '') }}"{% endif %} style="text-align:center;"><input type="checkbox" {% raw %}{%{% endraw %} if {{ section_component.primary_model }}.{{ attribute }} {% raw %}%}checked{% endif %}{% endraw %} disabled></td>

                {% elif attribute.type == AttributeType.DATE %}
                <td{% if has_theme %} class="{{ tokens.get('element.td', '') }}"{% endif %} style="text-align:center;">{% raw %}{{{% endraw %} {{ section_component.primary_model }}.{{ attribute }}|date:'Y-m-d' {% raw %}}}{% endraw %}</td>

                {% elif attribute.type == AttributeType.DATETIME %}
                <td{% if has_theme %} class="{{ tokens.get('element.td', '') }}"{% endif %} style="text-align:center;">{% raw %}{{{% endraw %} {{ section_component.primary_model }}.{{ attribute }}|date:'Y-m-d H:i' {% raw %}}}{% endraw %}</td>

                {% endif -%}
                {% endif -%}
                {% endfor %}
                {% for parent_model in section_component.parent_models %}
                <td{% if has_theme %} class="{{ tokens.get('element.td', '') }}"{% endif %} style="text-align:center;">
                    <select name="{{ parent_model }}"{% if has_theme %} class="{{ tokens.get('element.input.editable', '') }}"{% endif %}>
                        {% raw %}{%{% endraw %} for i in parent_{{ parent_model }}_list {% raw %}%}{% endraw %}
                        {% raw %}<option value="{{ i.id }}">{{ i }}</option>{% endraw %}
                        {% raw %}{% endfor %}{% endraw %}
                    </select>
                </td>
                {% endfor %}
                <td>
                    <input type="submit" value="Save"{% if has_theme %} class="{{ tokens.get('component.button.primary', '') }}"{% endif %}>
                </td>
                <td>
                    <a href="{% raw %}{%{% endraw %} url '{{ application_name }}:render_{{ application_name }}_{{ page }}' {% if page.type == 'activity' %}active_process_node_id{% endif %} {% raw %}%}{% endraw %}">Cancel</a>
                </td>
            </form>
            {% raw %}{% else %}{% endraw %}
            {% endif -%}
            
            {#- ATTRIBUTE VALUES #}
            {% for attribute in section_component.attributes -%}
            {% if attribute.type in [AttributeType.STRING, AttributeType.INTEGER, AttributeType.FLOAT, AttributeType.ENUM, AttributeType.EMAIL, AttributeType.TEXT] -%}
            <td{% if has_theme %} class="{{ tokens.get('element.td', '') }}"{% endif %} style="text-align:center;">{% raw %}{{{% endraw %} {{ section_component.primary_model }}.{{ attribute }} {% raw %}}}{% endraw %}</td>

            {%- elif attribute.type == AttributeType.BOOLEAN %}
            <td{% if has_theme %} class="{{ tokens.get('element.td', '') }}"{% endif %} style="text-align:center;"><input type="checkbox" {% raw %}{%{% endraw %} if {{ section_component.primary_model }}.{{ attribute }} {% raw %}%}checked{% endif %}{% endraw %} disabled></td>
            
            {%- elif attribute.type == AttributeType.DATE %}
            <td{% if has_theme %} class="{{ tokens.get('element.td', '') }}"{% endif %} style="text-align:center;">{% raw %}{{{% endraw %} {{ section_component.primary_model }}.{{ attribute }}|date:'Y-m-d' {% raw %}}}{% endraw %}</td>

            {%- elif attribute.type == AttributeType.DATETIME %}
            <td{% if has_theme %} class="{{ tokens.get('element.td', '') }}"{% endif %} style="text-align:center;">{% raw %}{{{% endraw %} {{ section_component.primary_model }}.{{ attribute }}|date:'Y-m-d H:i' {% raw %}}}{% endraw %}</td>

            {% endif -%}
            {% endfor -%}
            {% for parent_model in section_component.parent_models -%}
            <td{% if has_theme %} class="{{ tokens.get('element.td', '') }}"{% endif %} style="text-align:center;">{% raw %}{{{% endraw %} {{ section_component.primary_model }}.{{ parent_model }} {% raw %}}}{% endraw %}</td>
            {% endfor -%}
            {% if section_component.has_update_operation -%}
            {% raw %}{% endif %}{% endraw %}
            {% endif -%}

            {#- UPDATE #}
            {% if section_component.has_update_operation -%}

            {#- UPDATE BUTTON -#}
            {% raw %}{%{% endraw %} if {{ section_component.primary_model }} != update_instance {% raw %}%}{% endraw %}
            <td>
                <form action="{% raw %}{%{% endraw %} url '{{ application_name }}:render_{{ application_name }}_{{ page }}' {% if page.type == 'activity' %}active_process_node_id{% endif %}{% raw %}%}{% endraw %}" method="get">
                    <input type="hidden" name="instance_id_{{ section_component.primary_model }}"  value="{{ '{{' }}{{ section_component.primary_model }}.id {{ '}}' }}">
                    <label style="cursor:pointer;">
                        <input type="submit" style="display:none;" />
                        <svg width="20px" height="20px" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <path d="M21.2799 6.40005L11.7399 15.94C10.7899 16.89 7.96987 17.33 7.33987 16.7C6.70987 16.07 7.13987 13.25 8.08987 12.3L17.6399 2.75002C17.8754 2.49308 18.1605 2.28654 18.4781 2.14284C18.7956 1.99914 19.139 1.92124 19.4875 1.9139C19.8359 1.90657 20.1823 1.96991 20.5056 2.10012C20.8289 2.23033 21.1225 2.42473 21.3686 2.67153C21.6147 2.91833 21.8083 3.21243 21.9376 3.53609C22.0669 3.85976 22.1294 4.20626 22.1211 4.55471C22.1128 4.90316 22.0339 5.24635 21.8894 5.5635C21.7448 5.88065 21.5375 6.16524 21.2799 6.40005V6.40005Z" stroke="#000000" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                            <path d="M11 4H6C4.93913 4 3.92178 4.42142 3.17163 5.17157C2.42149 5.92172 2 6.93913 2 8V18C2 19.0609 2.42149 20.0783 3.17163 20.8284C3.92178 21.5786 4.93913 22 6 22H17C19.21 22 20 20.2 20 18V13" stroke="#000000" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                    </label>
                </form>
            </td>
            
            {% raw %}{% endif %}{% endraw %}
            {% endif -%}

            {#- DELETE BUTTON #}
            {% if section_component.has_delete_operation -%}
            <td>
                <form action="{% raw %}{%{% endraw %} url '{{ application_name }}:{{ page }}_{{ section_component }}_delete' {% if page.type == 'activity' %}active_process_node_id{% endif %} {{ section_component.primary_model }}.id {% raw %}%}{% endraw %}" method="post">
                    {% raw %}{% csrf_token %}{% endraw %}
                    <label style="cursor:pointer;">
                        <input type="submit" style="display:none;"/>
                        <svg width="20px" height="20px" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <path d="M10 12V17" stroke="#000000" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                            <path d="M14 12V17" stroke="#000000" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                            <path d="M4 7H20" stroke="#000000" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                            <path d="M6 10V18C6 19.6569 7.34315 21 9 21H15C16.6569 21 18 19.6569 18 18V10" stroke="#000000" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                            <path d="M9 5C9 3.89543 9.89543 3 11 3H13C14.1046 3 15 3.89543 15 5V7H9V5Z" stroke="#000000" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                    </label>
                </form>
            </td>
            {% endif %}

            {#- CUSTOM METHOD BUTTONS#}
            {% for custom_method in section_component.custom_methods -%}
            <td>
                <form action="{% raw %}{%{% endraw %} url '{{ application_name }}:render_{{ application_name }}_{{ page }}' {% if page.type == 'activity' %}active_process_node_id{% endif %} {% raw %}%}{% endraw %}" method="get">
                    <input type="hidden" name="custom_{{ section_component.primary_model }}_{{ custom_method }}" value="{{ '{{' }}{{ section_component.primary_model }}.id {{ '}}' }}">
                    <input type="submit" value="{{ custom_method }}"/>
                </form>
            </td>
            {% endfor -%}
        </tr>
        {% raw %}{% endfor %}{% endraw %}
        </tbody>
    </table>

    {#- ── PAGINATION ── #}
    <div class="pagination" data-table="table-{{ loop.index }}">
        <button class="page-btn page-prev" disabled>&laquo; Prev</button>
        <span class="page-info">Page <span class="page-current">1</span></span>
        <button class="page-btn page-next">Next &raquo;</button>
    </div>

    {#- ── CREATE BUTTON → opens modal ── #}
    {% if section_component.has_create_operation -%}
    <button class="create-open-btn" data-modal="modal-{{ loop.index }}">
        <svg width="20px" height="20px" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M15 12H12M12 12H9M12 12V9M12 12V15M17 21H7C4.79086 21 3 19.2091 3 17V7C3 4.79086 4.79086 3 7 3H17C19.2091 3 21 4.79086 21 7V17C21 19.2091 19.2091 21 17 21Z" stroke="#000000" stroke-width="2" stroke-linecap="round"/>
        </svg>
        Add {{ section_component.display_name }}
    </button>

    {#- ── MODAL FORM ── #}
    <div class="modal-overlay" id="modal-{{ loop.index }}">
        <div class="modal{% if has_theme %} {{ tokens.get('page.surface', '') }}{% endif %}">
            <div class="modal-header">
                <h3{% if has_theme %} class="{{ tokens.get('element.heading', '') }}"{% endif %}>Create {{ section_component.display_name }}</h3>
                <button class="modal-close">&times;</button>
            </div>
            <div class="modal-body">
                <form action="{% raw %}{%{% endraw %} url '{{ application_name }}:{{ page }}_{{ section_component }}_create' {% if page.type == 'activity' %}active_process_node_id{% endif %} {% raw %}%}{% endraw %}" method="post" class="modal-form{% if has_theme %} {{ tokens.get('region.form', '') }}{% endif %}">
                    {% raw %}{% csrf_token %}{% endraw %}
                    {% for attribute in section_component.attributes -%}
                    {% if attribute.derived -%}
                    {% else -%}
                    <div class="form-group">
                        <label for="create_{{ attribute }}"{% if has_theme %} class="{{ tokens.get('element.label', '') }}"{% endif %}>{{ attribute }}</label>
                        {% if attribute.type == AttributeType.STRING -%}
                        <input type="text" name="{{ attribute }}" id="create_{{ attribute }}" placeholder="{{ attribute }}"{% if has_theme %} class="{{ tokens.get('element.input.editable', '') }}"{% endif %}>
                        {% elif attribute.type == AttributeType.INTEGER -%}
                        <input type="number" name="{{ attribute }}" id="create_{{ attribute }}" placeholder="{{ attribute }}"{% if has_theme %} class="{{ tokens.get('element.input.editable', '') }}"{% endif %}>
                        {% elif attribute.type == AttributeType.FLOAT -%}
                        <input type="number" step="0.01" name="{{ attribute }}" id="create_{{ attribute }}" placeholder="{{ attribute }}"{% if has_theme %} class="{{ tokens.get('element.input.editable', '') }}"{% endif %}>
                        {% elif attribute.type == AttributeType.BOOLEAN -%}
                        <input type="checkbox" name="{{ attribute }}" id="create_{{ attribute }}"{% if has_theme %} class="{{ tokens.get('element.input.editable', '') }}"{% endif %}>
                        {% elif attribute.type == AttributeType.ENUM -%}
                        <select name="{{ attribute }}" id="create_{{ attribute }}"{% if has_theme %} class="{{ tokens.get('element.input.editable', '') }}"{% endif %}>
                            {% for literal in attribute.enum_literals %}
                                <option value="{{ literal }}">{{ literal }}</option>
                            {% endfor %}
                        </select>
                        {% elif attribute.type == AttributeType.DATE -%}
                        <input type="date" name="{{ attribute }}" id="create_{{ attribute }}"{% if has_theme %} class="{{ tokens.get('element.input.editable', '') }}"{% endif %}>
                        {% elif attribute.type == AttributeType.DATETIME -%}
                        <input type="datetime-local" name="{{ attribute }}" id="create_{{ attribute }}"{% if has_theme %} class="{{ tokens.get('element.input.editable', '') }}"{% endif %}>
                        {% elif attribute.type == AttributeType.TEXT -%}
                        <textarea name="{{ attribute }}" id="create_{{ attribute }}" rows="3" placeholder="{{ attribute }}"{% if has_theme %} class="{{ tokens.get('element.input.editable', '') }}"{% endif %}></textarea>
                        {% elif attribute.type == AttributeType.EMAIL -%}
                        <input type="email" name="{{ attribute }}" id="create_{{ attribute }}" placeholder="{{ attribute }}"{% if has_theme %} class="{{ tokens.get('element.input.editable', '') }}"{% endif %}>
                        {%- endif %}
                    </div>
                    {% endif -%}
                    {% endfor -%}
                    {% for parent_model in section_component.parent_models -%}
                    <div class="form-group">
                        <label for="create_{{ parent_model }}"{% if has_theme %} class="{{ tokens.get('element.label', '') }}"{% endif %}>{{ parent_model }}</label>
                        <select name="{{ parent_model }}" id="create_{{ parent_model }}"{% if has_theme %} class="{{ tokens.get('element.input.editable', '') }}"{% endif %}>
                            {% raw %}{%{% endraw %} for i in parent_{{ parent_model }}_list {% raw %}%}{% endraw %}
                            {% raw %}<option value="{{ i.id }}">{{ i }}</option>{% endraw %}
                            {% raw %}{% endfor %}{% endraw %}
                        </select>
                    </div>
                    {% endfor -%}
                    <div class="modal-actions">
                        <input type="submit" value="Save" class="btn-save{% if has_theme %} {{ tokens.get('component.button.primary', '') }}{% endif %}">
                        <button type="button" class="btn-cancel modal-close{% if has_theme %} {{ tokens.get('component.button.secondary', '') }}{% endif %}">Cancel</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
    {%- endif %}

    </div>{# /section-body #}

    {% if page.section_components | length > 1 and page.type != 'activity' %}
    </div>{# /tab-panel #}
    {% endif %}

    {% endfor %}

    {% if page.type == 'activity' %}
    <div style="position: fixed; bottom: 20px; right: 20px;">
        <form action="{% raw %}{%{% endraw %} url 'workflow_engine:complete_process_step' active_process_node_id {% raw %}%}{% endraw %}" method="post">
            {% raw %}{% csrf_token %}{% endraw %}
            <button type="submit" class="complete-activity-button">
                Complete task
            </button>
        </form>
    </div>
    {% endif %}
</div>

{#- ── JAVASCRIPT: tabs, search, pagination, modal, accordion ── #}
<script>
(function(){
    /* Tabs */
    document.querySelectorAll('.tab-btn').forEach(function(btn){
        btn.addEventListener('click', function(){
            var tabId = this.getAttribute('data-tab');
            this.closest('.tabs').querySelectorAll('.tab-btn').forEach(function(b){ b.classList.remove('tab-active'); b.setAttribute('aria-selected','false'); });
            this.classList.add('tab-active');
            this.setAttribute('aria-selected','true');
            document.querySelectorAll('.tab-panel').forEach(function(p){ p.classList.remove('tab-panel-active'); });
            document.getElementById(tabId).classList.add('tab-panel-active');
        });
    });
    /* Search */
    document.querySelectorAll('.search-input').forEach(function(input){
        input.addEventListener('input', function(){
            var q = this.value.toLowerCase();
            var tableId = this.getAttribute('data-table');
            var rows = document.querySelectorAll('#'+tableId+' tbody tr');
            rows.forEach(function(row){ row.style.display = row.textContent.toLowerCase().indexOf(q) > -1 ? '' : 'none'; });
        });
    });
    /* Pagination */
    var PAGE_SIZE = 10;
    document.querySelectorAll('.pagination').forEach(function(pag){
        var tableId = pag.getAttribute('data-table');
        var rows = document.querySelectorAll('#'+tableId+' tbody tr');
        var currentPage = 1;
        var totalPages = Math.max(1, Math.ceil(rows.length / PAGE_SIZE));
        function render(){
            rows.forEach(function(r,i){ r.style.display = (i >= (currentPage-1)*PAGE_SIZE && i < currentPage*PAGE_SIZE) ? '' : 'none'; });
            pag.querySelector('.page-current').textContent = currentPage;
            pag.querySelector('.page-prev').disabled = currentPage <= 1;
            pag.querySelector('.page-next').disabled = currentPage >= totalPages;
            if(rows.length <= PAGE_SIZE) pag.style.display = 'none';
        }
        pag.querySelector('.page-prev').addEventListener('click', function(){ if(currentPage>1){currentPage--;render();} });
        pag.querySelector('.page-next').addEventListener('click', function(){ if(currentPage<totalPages){currentPage++;render();} });
        render();
    });
    /* Modal */
    document.querySelectorAll('.create-open-btn').forEach(function(btn){
        btn.addEventListener('click', function(){ document.getElementById(this.getAttribute('data-modal')).classList.add('modal-visible'); });
    });
    document.querySelectorAll('.modal-close').forEach(function(btn){
        btn.addEventListener('click', function(){ this.closest('.modal-overlay').classList.remove('modal-visible'); });
    });
    document.querySelectorAll('.modal-overlay').forEach(function(overlay){
        overlay.addEventListener('click', function(e){ if(e.target === this) this.classList.remove('modal-visible'); });
    });
    /* Accordion */
    document.querySelectorAll('.section-header[data-accordion]').forEach(function(header){
        header.addEventListener('click', function(){
            var body = document.getElementById(this.getAttribute('data-accordion'));
            var icon = this.querySelector('.accordion-icon');
            if(body.classList.contains('section-body-collapsed')){ body.classList.remove('section-body-collapsed'); icon.textContent = '\u25BC'; }
            else { body.classList.add('section-body-collapsed'); icon.textContent = '\u25B6'; }
        });
    });
})();
</script>

{% raw %}{% endblock %}{% endraw %}