{% raw %}{%{% endraw %} extends "{{ application_name }}_base.html" {% raw %}%}{% endraw %}
{% raw %}{% block content %}{% endraw %}


<div class="space-y-10">
    {%- for section_component in page.section_components %}

    <div>
        {#- SECTION HEADER -#}
        <div class="flex items-center justify-between mb-4">
            <div>
                <h2 class="text-base font-semibold text-text-main">{{ section_component.display_name }}</h2>
                {% if section_component.text %}<div class="text-sm text-gray-500 mt-0.5">{{ section_component.text }}</div>{% endif %}
            </div>
            {#- ADD BUTTON (shown when create form is NOT open) -#}
            {% if section_component.has_create_operation -%}
            {% if not section_component.create_action_node_id or current_action_node_id == section_component.create_action_node_id %}
            {% raw %}{%{% endraw %} if not create_{{ section_component }} {% raw %}%}{% endraw %}
            <form action="{% raw %}{%{% endraw %} url '{{ application_name }}:render_{{ application_name }}_{{ page }}' {% raw %}%}{% endraw %}" method="get">
                <input type="hidden" name="create_{{ section_component }}" value="true">
                <button type="submit" class="btn text-sm px-3 py-1.5">+ Add {{ section_component.display_name }}</button>
            </form>
            {% raw %}{% endif %}{% endraw %}
            {%- endif %}
            {% endif -%}
        </div>

        {#- CREATE FORM CARD -#}
        {% if section_component.has_create_operation -%}
        {% if not section_component.create_action_node_id or current_action_node_id == section_component.create_action_node_id %}
        {% raw %}{%{% endraw %} if create_{{ section_component }} {% raw %}%}{% endraw %}
        <div class="bg-white rounded-custom border border-gray-200 p-5 mb-4 shadow-sm">
            <h3 class="text-sm font-semibold mb-4 text-accent">New {{ section_component.display_name }}</h3>
            <form action="{% raw %}{%{% endraw %} url '{{ application_name }}:{{ page }}_{{ section_component }}_create' {% raw %}%}{% endraw %}" method="post">
                {% raw %}{% csrf_token %}{% endraw %}
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-4">
                    {% for attribute in section_component.attributes -%}
                    {% if not attribute.derived -%}
                    <div class="field">
                        <label for="{{ attribute }}_c">{{ attribute.name | replace('_', ' ') | title }}</label>
                        {% if attribute.type == AttributeType.STRING -%}
                        <input type="text" name="{{ attribute }}" id="{{ attribute }}_c" placeholder="{{ attribute.name | replace('_', ' ') | title }}">
                        {%- elif attribute.type == AttributeType.INTEGER -%}
                        <input type="number" name="{{ attribute }}" id="{{ attribute }}_c" placeholder="0">
                        {%- elif attribute.type == AttributeType.DATE -%}
                        <input type="date" name="{{ attribute }}" id="{{ attribute }}_c">
                        {%- elif attribute.type == AttributeType.DATETIME -%}
                        <input type="datetime-local" name="{{ attribute }}" id="{{ attribute }}_c">
                        {%- elif attribute.type == AttributeType.BOOLEAN -%}
                        <input type="checkbox" name="{{ attribute }}" id="{{ attribute }}_c" class="mt-2">
                        {%- elif attribute.type == AttributeType.ENUM -%}
                        <select name="{{ attribute }}" id="{{ attribute }}_c">
                            {% for literal in attribute.enum_literals %}
                            <option value="{{ literal }}">{{ literal }}</option>
                            {% endfor %}
                        </select>
                        {%- endif %}
                    </div>
                    {%- endif %}
                    {%- endfor %}
                    {% for parent_model in section_component.parent_models -%}
                    <div class="field">
                        <label>{{ parent_model }}</label>
                        <select name="{{ parent_model }}" required>
                            <option value="">— Select {{ parent_model }} —</option>
                            {% raw %}{%{% endraw %} for i in parent_{{ parent_model }}_list {% raw %}%}{% endraw %}
                            {% raw %}<option value="{{ i.id }}">{{ i }}</option>{% endraw %}
                            {% raw %}{% endfor %}{% endraw %}
                        </select>
                    </div>
                    {%- endfor %}
                </div>
                <div class="flex gap-2">
                    <input type="submit" value="Save" class="btn">
                    <a href="{% raw %}{%{% endraw %} url '{{ application_name }}:render_{{ application_name }}_{{ page }}' {% raw %}%}{% endraw %}" class="btn btn-outline">Cancel</a>
                </div>
            </form>
        </div>
        {% raw %}{% endif %}{% endraw %}
        {%- endif %}
        {% endif -%}

        {# ======================================================
           Reusable macro: action buttons (edit / delete / custom)
           ====================================================== #}
        {%- macro action_buttons(primary_model, section_component, page, application_name) %}
        <div class="flex items-center gap-3">
            {% if section_component.has_update_operation -%}
            {% if not section_component.update_action_node_id or current_action_node_id == section_component.update_action_node_id %}
            {% raw %}{%{% endraw %} if {{ section_component.primary_model }} != update_instance {% raw %}%}{% endraw %}
            <form action="{% raw %}{%{% endraw %} url '{{ application_name }}:render_{{ application_name }}_{{ page }}' {% raw %}%}{% endraw %}" method="get">
                <input type="hidden" name="instance_id_{{ section_component.primary_model }}" value="{{ '{{' }}{{ section_component.primary_model }}.id {{ '}}' }}">
                <button type="submit" class="text-xs font-medium text-accent hover:underline">Edit</button>
            </form>
            {% raw %}{% endif %}{% endraw %}
            {% endif -%}
            {% endif -%}
            {% if section_component.has_delete_operation -%}
            {% if not section_component.delete_action_node_id or current_action_node_id == section_component.delete_action_node_id %}
            <form action="{% raw %}{%{% endraw %} url '{{ application_name }}:{{ page }}_{{ section_component }}_delete' {{ section_component.primary_model }}.id {% raw %}%}{% endraw %}" method="post">
                {% raw %}{% csrf_token %}{% endraw %}
                <button type="submit" class="text-xs font-medium text-red-500 hover:underline" onclick="return confirm('Delete this {{ section_component.display_name }}?')">Delete</button>
            </form>
            {% endif -%}
            {% endif %}
            {% for custom_method in section_component.custom_methods -%}
            <form action="{% raw %}{%{% endraw %} url '{{ application_name }}:render_{{ application_name }}_{{ page }}' {% raw %}%}{% endraw %}" method="get">
                <input type="hidden" name="custom_{{ section_component.primary_model }}_{{ custom_method }}" value="{{ '{{' }}{{ section_component.primary_model }}.id {{ '}}' }}">
                <button type="submit" class="text-xs font-medium text-accent hover:underline">{{ custom_method | replace('_', ' ') | title }}</button>
            </form>
            {% endfor -%}
        </div>
        {%- endmacro %}

        {# ======================================================
           Reusable macro: inline edit form cells
           ====================================================== #}
        {%- macro edit_form_cells(section_component, page, application_name) %}
        <form action="{% raw %}{%{% endraw %} url '{{ application_name }}:{{ page }}_{{ section_component }}_update' update_instance.id{% raw %}%}{% endraw %}" method="post" style="display:contents;">
            {% raw %}{% csrf_token %}{% endraw %}
            {% for attribute in section_component.attributes %}
            {% if attribute.updatable and not attribute.derived %}
            <td>
                {% if attribute.type == AttributeType.STRING %}<input type="text" name="{{ attribute }}" value="{% raw %}{{{% endraw %} update_instance.{{ attribute }} {% raw %}}}{% endraw %}">
                {%- elif attribute.type == AttributeType.INTEGER %}<input type="number" name="{{ attribute }}" value="{% raw %}{{{% endraw %} update_instance.{{ attribute }} {% raw %}}}{% endraw %}">
                {%- elif attribute.type == AttributeType.DATE %}<input type="date" name="{{ attribute }}" value="{% raw %}{{{% endraw %} update_instance.{{ attribute }}|date:'Y-m-d' {% raw %}}}{% endraw %}">
                {%- elif attribute.type == AttributeType.DATETIME %}<input type="datetime-local" name="{{ attribute }}" value="{% raw %}{{{% endraw %} update_instance.{{ attribute }}|date:'Y-m-d\TH:i' {% raw %}}}{% endraw %}">
                {%- elif attribute.type == AttributeType.BOOLEAN %}<input type="checkbox" name="{{ attribute }}" {% raw %}{%{% endraw %} if update_instance.{{ attribute }} {% raw %}%}checked{% endif %}{% endraw %}>
                {%- elif attribute.type == AttributeType.ENUM %}<select name="{{ attribute }}">{% for literal in attribute.enum_literals %}<option value="{{ literal }}">{{ literal }}</option>{% endfor %}</select>
                {%- endif %}
            </td>
            {% else %}
            <td>
                {% if attribute.type == AttributeType.BOOLEAN %}<input type="checkbox" {% raw %}{%{% endraw %} if {{ section_component.primary_model }}.{{ attribute }} {% raw %}%}checked{% endif %}{% endraw %} disabled>
                {% else %}{% raw %}{{{% endraw %} {{ section_component.primary_model }}.{{ attribute }} {% raw %}}}{% endraw %}{% endif %}
            </td>
            {% endif -%}
            {% endfor %}
            {% for parent_model in section_component.parent_models %}
            <td><select name="{{ parent_model }}">
                {% raw %}{%{% endraw %} for i in parent_{{ parent_model }}_list {% raw %}%}{% endraw %}{% raw %}<option value="{{ i.id }}">{{ i }}</option>{% endraw %}{% raw %}{% endfor %}{% endraw %}
            </select></td>
            {% endfor %}
            <td><div class="flex items-center gap-3">
                <input type="submit" value="Save" class="btn text-xs px-2 py-1">
                <a href="{% raw %}{%{% endraw %} url '{{ application_name }}:render_{{ application_name }}_{{ page }}' {% raw %}%}{% endraw %}" class="text-xs text-gray-500 hover:text-text-main">Cancel</a>
            </div></td>
        </form>
        {%- endmacro %}

        {# ========== TABLE MODE ========== #}
        {% if styling.display_mode == DisplayMode.TABLE %}
        <div class="bg-white rounded-custom shadow-sm overflow-hidden border border-gray-200">
            <table>
                <tr>
                    {%- for attribute in section_component.attributes %}
                    <th>{{ attribute.name | replace('_', ' ') | title }}</th>
                    {%- endfor %}
                    {%- for parent_model in section_component.parent_models %}
                    <th>{{ parent_model }}</th>
                    {%- endfor %}
                    {% if section_component.has_update_operation or section_component.has_delete_operation or section_component.custom_methods %}<th></th>{% endif %}
                </tr>
                {% raw %}{%{% endraw %} for {{ section_component.primary_model }} in {{ section_component.primary_model }}_list {% raw %}%}{% endraw %}
                <tr>
                    {% if section_component.has_update_operation -%}
                    {% raw %}{%{% endraw %} if {{ section_component.primary_model }} == update_instance {% raw %}%}{% endraw %}
                    {{ edit_form_cells(section_component, page, application_name) }}
                    {% raw %}{% else %}{% endraw %}
                    {% endif -%}
                    {% for attribute in section_component.attributes -%}
                    {% if loop.first -%}
                    <td><a href="{% raw %}{%{% endraw %} url '{{ application_name }}:{{ section_component.primary_model|lower }}_detail' {{ section_component.primary_model }}.id {% raw %}%}{% endraw %}" class="font-medium text-accent hover:underline">{% raw %}{{{% endraw %} {{ section_component.primary_model }}.{{ attribute }} {% raw %}}}{% endraw %}</a></td>
                    {%- elif attribute.type == AttributeType.BOOLEAN %}
                    <td><input type="checkbox" {% raw %}{%{% endraw %} if {{ section_component.primary_model }}.{{ attribute }} {% raw %}%}checked{% endif %}{% endraw %} disabled></td>
                    {%- elif attribute.type == AttributeType.ENUM %}
                    <td><span class="badge">{% raw %}{{{% endraw %} {{ section_component.primary_model }}.{{ attribute }} {% raw %}}}{% endraw %}</span></td>
                    {%- else %}
                    <td>{% raw %}{{{% endraw %} {{ section_component.primary_model }}.{{ attribute }} {% raw %}}}{% endraw %}</td>
                    {%- endif %}
                    {%- endfor %}
                    {% for parent_model in section_component.parent_models -%}
                    <td>{% raw %}{{{% endraw %} {{ section_component.primary_model }}.{{ parent_model }} {% raw %}}}{% endraw %}</td>
                    {% endfor -%}
                    {% if section_component.has_update_operation -%}
                    {% raw %}{% endif %}{% endraw %}
                    {% endif -%}
                    {% if section_component.has_update_operation or section_component.has_delete_operation or section_component.custom_methods %}
                    <td>{{ action_buttons(section_component.primary_model, section_component, page, application_name) }}</td>
                    {% endif %}
                </tr>
                {% raw %}{% endfor %}{% endraw %}
            </table>
        </div>

        {# ========== CARDS MODE ========== #}
        {% elif styling.display_mode == DisplayMode.CARDS %}
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
            {% raw %}{%{% endraw %} for {{ section_component.primary_model }} in {{ section_component.primary_model }}_list {% raw %}%}{% endraw %}
            <div class="card-item bg-white rounded-custom border border-gray-200 shadow-sm p-5 flex flex-col gap-3 hover:shadow-md transition-shadow">
                {#- Card title: first attribute as link -#}
                {% for attribute in section_component.attributes -%}
                {% if loop.first -%}
                <div class="flex items-start justify-between">
                    <a href="{% raw %}{%{% endraw %} url '{{ application_name }}:{{ section_component.primary_model|lower }}_detail' {{ section_component.primary_model }}.id {% raw %}%}{% endraw %}" class="font-semibold text-base text-accent hover:underline leading-tight">
                        {% raw %}{{{% endraw %} {{ section_component.primary_model }}.{{ attribute }} {% raw %}}}{% endraw %}
                    </a>
                    {% if section_component.has_update_operation or section_component.has_delete_operation or section_component.custom_methods %}
                    <div class="shrink-0 ml-2">{{ action_buttons(section_component.primary_model, section_component, page, application_name) }}</div>
                    {% endif %}
                </div>
                {%- endif %}
                {%- endfor %}
                {#- Remaining attributes as key-value rows -#}
                <div class="space-y-1.5 text-sm">
                    {% for attribute in section_component.attributes -%}
                    {% if not loop.first -%}
                    <div class="flex items-center justify-between">
                        <span class="text-gray-400 text-xs font-medium uppercase tracking-wide">{{ attribute.name | replace('_', ' ') | title }}</span>
                        <span class="text-text-main font-medium">
                            {% if attribute.type == AttributeType.BOOLEAN %}
                            <input type="checkbox" {% raw %}{%{% endraw %} if {{ section_component.primary_model }}.{{ attribute }} {% raw %}%}checked{% endif %}{% endraw %} disabled>
                            {%- elif attribute.type == AttributeType.ENUM %}
                            <span class="badge">{% raw %}{{{% endraw %} {{ section_component.primary_model }}.{{ attribute }} {% raw %}}}{% endraw %}</span>
                            {%- else %}
                            {% raw %}{{{% endraw %} {{ section_component.primary_model }}.{{ attribute }} {% raw %}}}{% endraw %}
                            {%- endif %}
                        </span>
                    </div>
                    {%- endif %}
                    {%- endfor %}
                    {% for parent_model in section_component.parent_models -%}
                    <div class="flex items-center justify-between">
                        <span class="text-gray-400 text-xs font-medium uppercase tracking-wide">{{ parent_model }}</span>
                        <span class="text-text-main font-medium">{% raw %}{{{% endraw %} {{ section_component.primary_model }}.{{ parent_model }} {% raw %}}}{% endraw %}</span>
                    </div>
                    {%- endfor %}
                </div>
            </div>
            {% raw %}{% endfor %}{% endraw %}
        </div>

        {# ========== LIST MODE ========== #}
        {% elif styling.display_mode == DisplayMode.LIST %}
        <div class="bg-white rounded-custom border border-gray-200 shadow-sm divide-y divide-gray-100">
            {% raw %}{%{% endraw %} for {{ section_component.primary_model }} in {{ section_component.primary_model }}_list {% raw %}%}{% endraw %}
            <div class="flex items-center gap-4 px-5 py-3 hover:bg-gray-50 transition-colors group">
                {#- Avatar circle with first letter -#}
                {% for attribute in section_component.attributes -%}
                {% if loop.first -%}
                <div class="w-9 h-9 rounded-full bg-accent-light text-accent flex items-center justify-center text-sm font-bold shrink-0">
                    {% raw %}{{{% endraw %} {{ section_component.primary_model }}.{{ attribute }}|first|upper {% raw %}}}{% endraw %}
                </div>
                <div class="flex-1 min-w-0">
                    <a href="{% raw %}{%{% endraw %} url '{{ application_name }}:{{ section_component.primary_model|lower }}_detail' {{ section_component.primary_model }}.id {% raw %}%}{% endraw %}" class="font-medium text-text-main hover:text-accent truncate block">
                        {% raw %}{{{% endraw %} {{ section_component.primary_model }}.{{ attribute }} {% raw %}}}{% endraw %}
                    </a>
                    {#- Subtitle: next 1-2 attributes inline -#}
                    <p class="text-xs text-gray-400 truncate">
                        {% for attr in section_component.attributes -%}
                        {% if not loop.first and loop.index <= 3 -%}
                        <span>{{ attr.name | replace('_', ' ') | title }}:
                            {% if attr.type == AttributeType.BOOLEAN %}
                            {% raw %}{%{% endraw %} if {{ section_component.primary_model }}.{{ attr }} {% raw %}%}{% endraw %}Yes{% raw %}{% else %}{% endraw %}No{% raw %}{% endif %}{% endraw %}
                            {%- elif attr.type == AttributeType.ENUM %}
                            <span class="badge">{% raw %}{{{% endraw %} {{ section_component.primary_model }}.{{ attr }} {% raw %}}}{% endraw %}</span>
                            {%- else %}
                            {% raw %}{{{% endraw %} {{ section_component.primary_model }}.{{ attr }} {% raw %}}}{% endraw %}
                            {%- endif %}
                        </span>{% if not loop.last and loop.index <= 2 %} &middot; {% endif %}
                        {%- endif %}
                        {%- endfor %}
                    </p>
                </div>
                {%- endif %}
                {%- endfor %}
                {#- Actions appear on hover -#}
                {% if section_component.has_update_operation or section_component.has_delete_operation or section_component.custom_methods %}
                <div class="shrink-0 opacity-0 group-hover:opacity-100 transition-opacity">
                    {{ action_buttons(section_component.primary_model, section_component, page, application_name) }}
                </div>
                {% endif %}
            </div>
            {% raw %}{% endfor %}{% endraw %}
        </div>
        {% endif %}{# end display_mode #}

    </div>

    {% endfor %}

    {% raw %}{%{% endraw %} if active_process_node_id {% raw %}%}{% endraw %}
    <div class="fixed bottom-6 right-6">
        <form action="{% raw %}{%{% endraw %} url 'workflow_engine:complete_process_step' active_process_node_id {% raw %}%}{% endraw %}" method="post">
            {% raw %}{% csrf_token %}{% endraw %}
            <button type="submit" class="btn px-5 py-2.5 shadow-lg">Complete task</button>
        </form>
    </div>
    {% raw %}{% endif %}{% endraw %}
</div>

{% raw %}{% endblock %}{% endraw %}