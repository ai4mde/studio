{% raw %}{%{% endraw %} extends "{{ application_name }}_base.html" {% raw %}%}{% endraw %}
{% raw %}{% block content %}{% endraw %}

{# ── Style resolution ── #}
{% set color_map = {
  "blue":   {"btn": "bg-blue-600 hover:bg-blue-700", "light": "bg-blue-50", "text": "text-blue-600", "border": "border-blue-200", "label": "text-blue-700", "ring": "focus:ring-blue-500", "header_bg": "bg-blue-600"},
  "green":  {"btn": "bg-green-600 hover:bg-green-700", "light": "bg-green-50", "text": "text-green-600", "border": "border-green-200", "label": "text-green-700", "ring": "focus:ring-green-500", "header_bg": "bg-green-600"},
  "purple": {"btn": "bg-purple-600 hover:bg-purple-700", "light": "bg-purple-50", "text": "text-purple-600", "border": "border-purple-200", "label": "text-purple-700", "ring": "focus:ring-purple-500", "header_bg": "bg-purple-600"},
  "orange": {"btn": "bg-orange-500 hover:bg-orange-600", "light": "bg-orange-50", "text": "text-orange-500", "border": "border-orange-200", "label": "text-orange-700", "ring": "focus:ring-orange-400", "header_bg": "bg-orange-500"},
  "rose":   {"btn": "bg-rose-600 hover:bg-rose-700", "light": "bg-rose-50", "text": "text-rose-600", "border": "border-rose-200", "label": "text-rose-700", "ring": "focus:ring-rose-500", "header_bg": "bg-rose-600"},
  "slate":  {"btn": "bg-slate-700 hover:bg-slate-800", "light": "bg-slate-50", "text": "text-slate-600", "border": "border-slate-200", "label": "text-slate-700", "ring": "focus:ring-slate-500", "header_bg": "bg-slate-700"},
} %}
{% set c = color_map.get(color, color_map["blue"]) %}

{% set radius_map = {"none": "rounded-none", "sm": "rounded-sm", "md": "rounded-md", "lg": "rounded-lg", "xl": "rounded-xl", "2xl": "rounded-2xl"} %}
{% set r = radius_map.get(radius, "rounded-xl") %}

{% set density_map = {
  "compact":  {"gap": "gap-1", "p": "p-3", "row_py": "py-2 px-4", "text": "text-xs", "gap_section": "mb-8"},
  "normal":   {"gap": "gap-2", "p": "p-4", "row_py": "py-3 px-5", "text": "text-sm", "gap_section": "mb-12"},
  "spacious": {"gap": "gap-3", "p": "p-6", "row_py": "py-4 px-6", "text": "text-base", "gap_section": "mb-16"},
} %}
{% set d = density_map.get(density, density_map["normal"]) %}

<div class="{{ d.p }} max-w-full">
    {% if page.type == 'activity' %}<h2 class="text-2xl font-bold mb-6 text-gray-800">{{ page.activity_name }}</h2>{% endif %}

    {%- for section_component in page.section_components %}
    <div class="{{ d.gap_section }}">

        {% if page.type != 'activity' %}
        <h2 class="text-xl font-semibold text-gray-800 mb-1">{{ section_component.display_name }}</h2>
        {% endif %}

        {% if page.type == 'activity' %}
        <p class="text-gray-600 mb-4">{{ loop.index }}. {{ section_component.text }}</p>
        {% else %}
        <p class="text-gray-500 mb-4 {{ d.text }}">{{ section_component.text }}</p>
        {% endif %}

        <div class="bg-white border border-gray-200 {{ r }} overflow-hidden">

            {#- COLUMN HEADERS #}
            <div class="grid border-b border-gray-200 {{ d.row_py }} {{ c.header_bg }} text-white" style="grid-template-columns: repeat({{ section_component.attributes | length + section_component.parent_models | length }}, 1fr) auto;">
                {% for attribute in section_component.attributes %}
                <span class="{{ d.text }} font-semibold uppercase tracking-wide">{{ attribute }}</span>
                {% endfor %}
                {% for parent_model in section_component.parent_models %}
                <span class="{{ d.text }} font-semibold uppercase tracking-wide">{{ parent_model }}</span>
                {% endfor %}
                {% if section_component.has_update_operation or section_component.has_delete_operation or section_component.custom_methods %}
                <span class="{{ d.text }} font-semibold uppercase tracking-wide text-right">Actions</span>
                {% endif %}
            </div>

            {#- LIST ROWS #}
            {% raw %}{%{% endraw %} for {{ section_component.primary_model }} in {{ section_component.primary_model }}_list {% raw %}%}{% endraw %}

            {#- UPDATE FORM ROW #}
            {% if section_component.has_update_operation -%}
            {% raw %}{%{% endraw %} if {{ section_component.primary_model }} == update_instance {% raw %}%}{% endraw %}
            <form action="{% raw %}{%{% endraw %} url '{{ application_name }}:render_{{ application_name }}_{{ page }}' {% if page.type == 'activity' %}active_process_node_id{% endif %}{% raw %}%}{% endraw %}" method="post" class="border-b border-gray-100 {{ d.row_py }} bg-{{ color }}-50 flex flex-wrap gap-3 items-center">
                {% raw %}{% csrf_token %}{% endraw %}
                {% for attribute in section_component.attributes %}
                {% if attribute.updatable and not attribute.derived %}
                <div class="flex flex-col gap-0.5 flex-1 min-w-[120px]">
                    <label class="text-xs text-gray-400 uppercase">{{ attribute }}</label>
                    {% if attribute.type == AttributeType.STRING %}
                    <input type="text" name="{{ attribute }}" value="{% raw %}{{{% endraw %} update_instance.{{ attribute }} {% raw %}}}{% endraw %}" class="border border-gray-300 rounded px-2 py-1 {{ d.text }} {{ c.ring }} focus:outline-none focus:ring-2 w-full">
                    {%- elif attribute.type == AttributeType.INTEGER %}
                    <input type="number" name="{{ attribute }}" value="{% raw %}{{{% endraw %} update_instance.{{ attribute }} {% raw %}}}{% endraw %}" class="border border-gray-300 rounded px-2 py-1 {{ d.text }} {{ c.ring }} focus:outline-none focus:ring-2 w-full">
                    {%- elif attribute.type == AttributeType.BOOLEAN %}
                    <input type="checkbox" name="{{ attribute }}" {% raw %}{%{% endraw %} if update_instance.{{ attribute }} {% raw %}%}checked{% endif %}{% endraw %} class="h-4 w-4 rounded mt-1">
                    {%- elif attribute.type == AttributeType.ENUM %}
                    <select name="{{ attribute }}" class="border border-gray-300 rounded px-2 py-1 {{ d.text }} {{ c.ring }} focus:outline-none focus:ring-2 w-full">
                        {% for literal in attribute.enum_literals %}
                        <option value="{{ literal }}">{{ literal }}</option>
                        {% endfor %}
                    </select>
                    {%- endif %}
                </div>
                {% else %}
                <div class="flex flex-col gap-0.5 flex-1 min-w-[120px]">
                    <span class="text-xs text-gray-400 uppercase">{{ attribute }}</span>
                    {% if attribute.type == AttributeType.BOOLEAN %}
                    <input type="checkbox" {% raw %}{%{% endraw %} if update_instance.{{ attribute }} {% raw %}%}checked{% endif %}{% endraw %} disabled class="h-4 w-4 rounded mt-1">
                    {% else %}
                    <span class="{{ d.text }} text-gray-700">{% raw %}{{{% endraw %} update_instance.{{ attribute }} {% raw %}}}{% endraw %}</span>
                    {% endif %}
                </div>
                {% endif %}
                {% endfor %}
                {% for parent_model in section_component.parent_models %}
                <div class="flex flex-col gap-0.5 flex-1 min-w-[120px]">
                    <label class="text-xs text-gray-400 uppercase">{{ parent_model }}</label>
                    <select name="{{ parent_model }}" class="border border-gray-300 rounded px-2 py-1 {{ d.text }} {{ c.ring }} focus:outline-none focus:ring-2 w-full">
                        {% raw %}{%{% endraw %} for i in parent_{{ parent_model }}_list {% raw %}%}{% endraw %}
                        {% raw %}<option value="{{ i.id }}">{{ i }}</option>{% endraw %}
                        {% raw %}{% endfor %}{% endraw %}
                    </select>
                </div>
                {% endfor %}
                <div class="flex gap-2 ml-auto">
                    <input type="submit" value="Save" class="{{ c.btn }} text-white {{ d.text }} font-medium py-1.5 px-4 rounded cursor-pointer">
                    <a href="{% raw %}{%{% endraw %} url '{{ application_name }}:render_{{ application_name }}_{{ page }}' {% if page.type == 'activity' %}active_process_node_id{% endif %} {% raw %}%}{% endraw %}" class="bg-gray-100 text-gray-600 {{ d.text }} font-medium py-1.5 px-4 rounded hover:bg-gray-200">Cancel</a>
                </div>
            </form>
            {% raw %}{% else %}{% endraw %}
            {% endif -%}

            {#- DISPLAY ROW (inside Django else) #}
            <div class="grid border-b border-gray-100 {{ d.row_py }} hover:bg-gray-50 transition-colors items-center" style="grid-template-columns: repeat({{ section_component.attributes | length + section_component.parent_models | length }}, 1fr) auto;">
                {% for attribute in section_component.attributes -%}
                <div>
                    {% if attribute.type == AttributeType.BOOLEAN -%}
                    <input type="checkbox" {% raw %}{%{% endraw %} if {{ section_component.primary_model }}.{{ attribute }} {% raw %}%}checked{% endif %}{% endraw %} disabled class="h-4 w-4 rounded">
                    {%- else %}
                    <span class="{{ d.text }} text-gray-800">{% raw %}{{{% endraw %} {{ section_component.primary_model }}.{{ attribute }} {% raw %}}}{% endraw %}</span>
                    {% endif -%}
                </div>
                {% endfor -%}
                {% for parent_model in section_component.parent_models -%}
                <div>
                    <span class="{{ d.text }} text-gray-800">{% raw %}{{{% endraw %} {{ section_component.primary_model }}.{{ parent_model }} {% raw %}}}{% endraw %}</span>
                </div>
                {% endfor -%}

                {#- ROW ACTION BUTTONS #}
                <div class="flex gap-2 justify-end">
                    {%- if section_component.has_update_operation %}
                    {% raw %}{%{% endraw %} if {{ section_component.primary_model }} != update_instance {% raw %}%}{% endraw %}
                    <form action="{% raw %}{%{% endraw %} url '{{ application_name }}:render_{{ application_name }}_{{ page }}' {% if page.type == 'activity' %}active_process_node_id{% endif %}{% raw %}%}{% endraw %}" method="get">
                        <input type="hidden" name="instance_id_{{ section_component.primary_model }}" value="{{ '{{' }}{{ section_component.primary_model }}.id{{ '}}' }}">
                        <button type="submit" class="{{ d.text }} {{ c.text }} hover:opacity-70 font-medium py-1 px-3 rounded hover:{{ c.light }} transition-colors">Edit</button>
                    </form>
                    {% raw %}{% endif %}{% endraw %}
                    {% endif -%}

                    {%- if section_component.has_delete_operation %}
                    <form action="{% raw %}{%{% endraw %} url '{{ application_name }}:{{ page }}_{{ section_component }}_delete' {% if page.type == 'activity' %}active_process_node_id{% endif %} {{ section_component.primary_model }}.id {% raw %}%}{% endraw %}" method="post">
                        {% raw %}{% csrf_token %}{% endraw %}
                        <button type="submit" class="{{ d.text }} text-red-500 hover:text-red-700 font-medium py-1 px-3 rounded hover:bg-red-50 transition-colors">Delete</button>
                    </form>
                    {% endif -%}

                    {%- for custom_method in section_component.custom_methods %}
                    <form action="{% raw %}{%{% endraw %} url '{{ application_name }}:render_{{ application_name }}_{{ page }}' {% if page.type == 'activity' %}active_process_node_id{% endif %} {% raw %}%}{% endraw %}" method="get">
                        <input type="hidden" name="custom_{{ section_component.primary_model }}_{{ custom_method }}" value="{{ '{{' }}{{ section_component.primary_model }}.id{{ '}}' }}">
                        <button type="submit" class="{{ d.text }} text-gray-600 font-medium py-1 px-3 rounded border border-gray-200 hover:bg-gray-50 transition-colors">{{ custom_method }}</button>
                    </form>
                    {% endfor -%}
                </div>
            </div>

            {%- if section_component.has_update_operation %}
            {% raw %}{% endif %}{% endraw %}
            {% endif -%}

            {% raw %}{% endfor %}{% endraw %}

            {#- CREATE FORM ROW #}
            {%- if section_component.has_create_operation %}
            {% raw %}{%{% endraw %} if create_{{ section_component }} {% raw %}%}{% endraw %}
            <form action="{% raw %}{%{% endraw %} url '{{ application_name }}:{{ page }}_{{ section_component }}_create' {% if page.type == 'activity' %}active_process_node_id{% endif %} {% raw %}%}{% endraw %}" method="post" class="{{ d.row_py }} {{ c.light }} border-t-2 {{ c.border }} flex flex-wrap gap-3 items-end">
                {% raw %}{% csrf_token %}{% endraw %}
                {% for attribute in section_component.attributes -%}
                {% if not attribute.derived -%}
                <div class="flex flex-col gap-0.5 flex-1 min-w-[120px]">
                    <label class="text-xs {{ c.label }} font-medium uppercase">{{ attribute }}</label>
                    {% if attribute.type == AttributeType.STRING -%}
                    <input type="text" name="{{ attribute }}" placeholder="{{ attribute }}" class="border {{ c.border }} bg-white rounded px-2 py-1 {{ d.text }} {{ c.ring }} focus:outline-none focus:ring-2 w-full">
                    {% elif attribute.type == AttributeType.INTEGER -%}
                    <input type="number" name="{{ attribute }}" placeholder="{{ attribute }}" class="border {{ c.border }} bg-white rounded px-2 py-1 {{ d.text }} {{ c.ring }} focus:outline-none focus:ring-2 w-full">
                    {% elif attribute.type == AttributeType.BOOLEAN -%}
                    <input type="checkbox" name="{{ attribute }}" class="h-4 w-4 rounded mt-1">
                    {% elif attribute.type == AttributeType.ENUM -%}
                    <select name="{{ attribute }}" class="border {{ c.border }} bg-white rounded px-2 py-1 {{ d.text }} {{ c.ring }} focus:outline-none focus:ring-2 w-full">
                        {% for literal in attribute.enum_literals %}
                        <option value="{{ literal }}">{{ literal }}</option>
                        {% endfor %}
                    </select>
                    {%- endif %}
                </div>
                {% endif -%}
                {% endfor -%}
                {% for parent_model in section_component.parent_models -%}
                <div class="flex flex-col gap-0.5 flex-1 min-w-[120px]">
                    <label class="text-xs {{ c.label }} font-medium uppercase">{{ parent_model }}</label>
                    <select name="{{ parent_model }}" class="border {{ c.border }} bg-white rounded px-2 py-1 {{ d.text }} {{ c.ring }} focus:outline-none focus:ring-2 w-full">
                        {% raw %}{%{% endraw %} for i in parent_{{ parent_model }}_list {% raw %}%}{% endraw %}
                        {% raw %}<option value="{{ i.id }}">{{ i }}</option>{% endraw %}
                        {% raw %}{% endfor %}{% endraw %}
                    </select>
                </div>
                {% endfor -%}
                <div class="flex gap-2 ml-auto">
                    <input type="submit" value="Save" class="{{ c.btn }} text-white {{ d.text }} font-medium py-1.5 px-4 rounded cursor-pointer">
                    <a href="{% raw %}{%{% endraw %} url '{{ application_name }}:render_{{ application_name }}_{{ page }}' {% if page.type == 'activity' %}active_process_node_id{% endif %} {% raw %}%}{% endraw %}" class="bg-white text-gray-600 {{ d.text }} font-medium py-1.5 px-4 rounded border border-gray-200 hover:bg-gray-50">Cancel</a>
                </div>
            </form>
            {% raw %}{% endif %}{% endraw %}
            {% endif -%}

        </div>

        {#- CREATE BUTTON #}
        {%- if section_component.has_create_operation %}
        {% raw %}{%{% endraw %} if not create_{{ section_component }} {% raw %}%}{% endraw %}
        <form action="{% raw %}{%{% endraw %} url '{{ application_name }}:render_{{ application_name }}_{{ page }}' {% if page.type == 'activity' %}active_process_node_id{% endif %} {% raw %}%}{% endraw %}" method="get" class="mt-3">
            <input type="hidden" name="create_{{ section_component }}" value="true">
            <button type="submit" class="flex items-center gap-2 {{ d.text }} font-medium {{ c.text }} py-2 px-4 {{ r }} border {{ c.border }} hover:{{ c.light }} transition-colors">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M12 5v14M5 12h14"/></svg>
                Add {{ section_component.display_name }}
            </button>
        </form>
        {% raw %}{% endif %}{% endraw %}
        {%- endif %}

    </div>
    {% endfor %}

    {% if page.type == 'activity' %}
    <div class="fixed bottom-6 right-6">
        <form action="{% raw %}{%{% endraw %} url 'workflow_engine:complete_process_step' active_process_node_id {% raw %}%}{% endraw %}" method="post">
            {% raw %}{% csrf_token %}{% endraw %}
            <button type="submit" class="bg-green-600 text-white font-semibold py-3 px-6 {{ r }} shadow-lg hover:bg-green-700 transition-colors">Complete task</button>
        </form>
    </div>
    {% endif %}
</div>

{% raw %}{% endblock %}{% endraw %}
