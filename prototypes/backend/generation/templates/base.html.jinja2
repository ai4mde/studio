{% raw %}{% load static %}{% endraw %}
{%- set tokens = theme.get('tokens', {}) if theme else {} -%}
{%- set has_theme = tokens | length > 0 -%}
{# ── Detect LLM-designed layout elements ── #}
{%- set gl = global_layout if global_layout else {} -%}
{%- set has_gl = gl | length > 0 -%}
{%- if has_gl -%}
  {%- set gl_top_parts = [] -%}
  {%- set gl_left_parts = [] -%}
  {%- set gl_right_parts = [] -%}
  {%- set gl_bottom_parts = [] -%}
  {%- for key, val in gl.items() -%}
    {%- if val is mapping and val.get('html') -%}
      {%- if val.get('position') == 'top' -%}
        {%- set _ = gl_top_parts.append(val['html']) -%}
      {%- elif val.get('position') == 'left' -%}
        {%- set _ = gl_left_parts.append(val['html']) -%}
      {%- elif val.get('position') == 'right' -%}
        {%- set _ = gl_right_parts.append(val['html']) -%}
      {%- elif val.get('position') == 'bottom' -%}
        {%- set _ = gl_bottom_parts.append(val['html']) -%}
      {%- endif -%}
    {%- endif -%}
  {%- endfor -%}
{%- endif -%}
<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <title>{{ application_name }}</title>
        {% if has_theme %}
        <script src="https://cdn.tailwindcss.com"></script>
        {% endif %}
            <link rel="stylesheet" href='{% raw %}{%{% endraw %} static '{{ application_name }}/{{ application_name }}_style.css' {% raw %}%}{% endraw %}'>
    </head>

    <body{% if has_theme %} class="{{ tokens.get('page.body', '') }}"{% endif %}>
        {% if has_gl %}
        {# ── LLM-designed layout: use global_layout HTML elements ── #}
        {% for html in gl_top_parts %}
        {{ html }}
        {% endfor %}
        {% if gl_left_parts or gl_right_parts %}
        <div style="display: flex; min-height: calc(100vh - 60px);">
            {% for html in gl_left_parts %}
            {{ html }}
            {% endfor %}
            <div class="content{% if has_theme %} {{ tokens.get('page.main', '') }}{% endif %}" style="flex: 1;">
                {% raw %}
                <nav class="breadcrumbs" aria-label="breadcrumb">
                    <a href="{% url '{% endraw %}{{ application_name }}:{{ application_name }}-homerender{% raw %}' %}">Home</a>
                    {% block breadcrumbs %}{% endblock %}
                </nav>
                {% block content %}
                {% endblock %}
                {% endraw %}
            </div>
            {% for html in gl_right_parts %}
            {{ html }}
            {% endfor %}
        </div>
        {% else %}
        <div class="content{% if has_theme %} {{ tokens.get('page.main', '') }}{% endif %}">
            {% raw %}
            <nav class="breadcrumbs" aria-label="breadcrumb">
                <a href="{% url '{% endraw %}{{ application_name }}:{{ application_name }}-homerender{% raw %}' %}">Home</a>
                {% block breadcrumbs %}{% endblock %}
            </nav>
            {% block content %}
            {% endblock %}
            {% endraw %}
        </div>
        {% endif %}
        {% for html in gl_bottom_parts %}
        {{ html }}
        {% endfor %}

        {% elif styling.layout_type == LayoutType.TOP_NAV %}
        {# ── TOP_NAV: horizontal navigation bar, no sidebar ── #}
        <div class="header{% if has_theme %} {{ tokens.get('region.header', '') }}{% endif %}">
            <div class="logo">
                <img src='{{ logo }}'>
            </div>
            <h1{% if has_theme %} class="{{ tokens.get('element.heading', '') }}"{% endif %}>{{ application_name | capitalize }}</h1>
        </div>
        <nav class="topnav{% if has_theme %} {{ tokens.get('region.nav', '') }}{% endif %}">
            <a href="{% raw %}{%{% endraw %} url '{{ application_name }}:{{ application_name }}-homerender' {% raw %}%}{% endraw %}">Home</a>
            {% if settings.manager_access %}
            <a href="{% raw %}{%{% endraw %} url '{{ application_name }}:{{ application_name }}_action_log' {% raw %}%}{% endraw %}">Activity log</a>
            <a href="{% raw %}{%{% endraw %} url '{{ application_name }}:{{ application_name }}_change_user_assignment' {% raw %}%}{% endraw %}">User assignment</a>
            {% endif %}
            {% for category in categories %}
            {% for page in pages %}
            {% if page.type == 'normal'%}
            {% if page.category == category.name %}
            <a href="{% raw %}{%{% endraw %} url '{{ application_name }}:render_{{ page.application }}_{{ page }}' {% raw %}%}{% endraw %}">{{ page.display_name }}</a>
            {% endif %}
            {% endif %}
            {% endfor %}
            {% endfor %}
            {% for page in pages %}
            {% if page.category in ["", none] and page.type != 'activity' %}
            <a href="{% raw %}{%{% endraw %} url '{{ application_name }}:render_{{ page.application }}_{{ page }}' {% raw %}%}{% endraw %}">{{ page.display_name }}</a>
            {% endif %}
            {% endfor %}
            {% if authentication_present -%}
            {% raw %}<a href="{% url 'logout' %}">Logout</a>{% endraw %}
            {% else -%}
            {% raw %}<a href="{% url 'noauth_home-homerender' %}">Other Application</a>{% endraw %}
            {% endif -%}
        </nav>
        <div class="content content-topnav{% if has_theme %} {{ tokens.get('page.main', '') }}{% endif %}">
            {% raw %}
            <nav class="breadcrumbs" aria-label="breadcrumb">
                <a href="{% url '{% endraw %}{{ application_name }}:{{ application_name }}-homerender{% raw %}' %}">Home</a>
                {% block breadcrumbs %}{% endblock %}
            </nav>
            {% block content %}
            {% endblock %}
            {% endraw %}
        </div>

        {% elif styling.layout_type == LayoutType.TOP_NAV_SIDEBAR %}
        {# ── TOP_NAV_SIDEBAR: top header + left sidebar sub-nav ── #}
        <div class="header{% if has_theme %} {{ tokens.get('region.header', '') }}{% endif %}">
            <div class="logo">
                <img src='{{ logo }}'>
            </div>
            <h1{% if has_theme %} class="{{ tokens.get('element.heading', '') }}"{% endif %}>{{ application_name | capitalize }}</h1>
            <nav class="topnav-inline{% if has_theme %} {{ tokens.get('region.nav', '') }}{% endif %}">
                {% for category in categories %}
                <a href="#cat-{{ category.name }}">{{ category }}</a>
                {% endfor %}
                {% if authentication_present -%}
                {% raw %}<a href="{% url 'logout' %}">Logout</a>{% endraw %}
                {% else -%}
                {% raw %}<a href="{% url 'noauth_home-homerender' %}">Other Application</a>{% endraw %}
                {% endif -%}
            </nav>
        </div>
        <div class="menu{% if has_theme %} {{ tokens.get('region.nav', '') }}{% endif %}">
            <a href="{% raw %}{%{% endraw %} url '{{ application_name }}:{{ application_name }}-homerender' {% raw %}%}{% endraw %}">Home</a>
            {% if settings.manager_access %}
            <b>Manager</b>
            <a href="{% raw %}{%{% endraw %} url '{{ application_name }}:{{ application_name }}_action_log' {% raw %}%}{% endraw %}">Activity log</a>
            <a href="{% raw %}{%{% endraw %} url '{{ application_name }}:{{ application_name }}_change_user_assignment' {% raw %}%}{% endraw %}">User assignment</a>
            {% endif %}
            {% for category in categories %}
            <b>{{ category }}</b>
            {% for page in pages %}
            {% if page.type == 'normal'%}
            {% if page.category == category.name %}
            <a href="{% raw %}{%{% endraw %} url '{{ application_name }}:render_{{ page.application }}_{{ page }}' {% raw %}%}{% endraw %}">{{ page.display_name }}</a>
            {% endif %}
            {% endif %}
            {% endfor %}
            {% endfor %}
            {% for page in pages %}
            {% if page.category in ["", none] and page.type != 'activity' %}
            <a href="{% raw %}{%{% endraw %} url '{{ application_name }}:render_{{ page.application }}_{{ page }}' {% raw %}%}{% endraw %}">{{ page.display_name }}</a>
            {% endif %}
            {% endfor %}
        </div>
        <div class="content{% if has_theme %} {{ tokens.get('page.main', '') }}{% endif %}">
            {% raw %}
            <nav class="breadcrumbs" aria-label="breadcrumb">
                <a href="{% url '{% endraw %}{{ application_name }}:{{ application_name }}-homerender{% raw %}' %}">Home</a>
                {% block breadcrumbs %}{% endblock %}
            </nav>
            {% block content %}
            {% endblock %}
            {% endraw %}
        </div>

        {% elif styling.layout_type == LayoutType.SIDEBAR_RIGHT %}
        {# ── SIDEBAR_RIGHT: content left, sidebar right ── #}
        <div class="header{% if has_theme %} {{ tokens.get('region.header', '') }}{% endif %}">
            <div class="logo">
                <img src='{{ logo }}'>
            </div>
            <h1{% if has_theme %} class="{{ tokens.get('element.heading', '') }}"{% endif %}>{{ application_name | capitalize }}</h1>
        </div>
        <div class="content content-sidebar-right{% if has_theme %} {{ tokens.get('page.main', '') }}{% endif %}">
            {% raw %}
            <nav class="breadcrumbs" aria-label="breadcrumb">
                <a href="{% url '{% endraw %}{{ application_name }}:{{ application_name }}-homerender{% raw %}' %}">Home</a>
                {% block breadcrumbs %}{% endblock %}
            </nav>
            {% block content %}
            {% endblock %}
            {% endraw %}
        </div>
        <div class="menu menu-right{% if has_theme %} {{ tokens.get('region.nav', '') }}{% endif %}">
            <a href="{% raw %}{%{% endraw %} url '{{ application_name }}:{{ application_name }}-homerender' {% raw %}%}{% endraw %}">Home</a>
            {% if settings.manager_access %}
            <b>Manager</b>
            <a href="{% raw %}{%{% endraw %} url '{{ application_name }}:{{ application_name }}_action_log' {% raw %}%}{% endraw %}">Activity log</a>
            <a href="{% raw %}{%{% endraw %} url '{{ application_name }}:{{ application_name }}_change_user_assignment' {% raw %}%}{% endraw %}">User assignment</a>
            {% endif %}
            {% for category in categories %}
            <b>{{ category }}</b>
            {% for page in pages %}
            {% if page.type == 'normal'%}
            {% if page.category == category.name %}
            <a href="{% raw %}{%{% endraw %} url '{{ application_name }}:render_{{ page.application }}_{{ page }}' {% raw %}%}{% endraw %}">{{ page.display_name }}</a>
            {% endif %}
            {% endif %}
            {% endfor %}
            {% endfor %}
            {% for page in pages %}
            {% if page.category in ["", none] and page.type != 'activity' %}
            <a href="{% raw %}{%{% endraw %} url '{{ application_name }}:render_{{ page.application }}_{{ page }}' {% raw %}%}{% endraw %}">{{ page.display_name }}</a>
            {% endif %}
            {% endfor %}
            {% if authentication_present -%}
            {% raw %}<a href="{% url 'logout' %}">Logout</a>{% endraw %}
            {% else -%}
            {% raw %}<a href="{% url 'noauth_home-homerender' %}">Other Application</a>{% endraw %}
            {% endif -%}
        </div>

        {% else %}
        {# ── SIDEBAR_LEFT (default): original layout ── #}
        <div class="header{% if has_theme %} {{ tokens.get('region.header', '') }}{% endif %}">
            <div class="logo">
                <img src='{{ logo }}'>
            </div>
            <h1{% if has_theme %} class="{{ tokens.get('element.heading', '') }}"{% endif %}>{{ application_name | capitalize }}</h1>
        </div>
            <div class="menu{% if has_theme %} {{ tokens.get('region.nav', '') }}{% endif %}">
                <a href="{% raw %}{%{% endraw %} url '{{ application_name }}:{{ application_name }}-homerender' {% raw %}%}{% endraw %}">Home</a>
                {% if settings.manager_access %}
                <b>Manager</b>
                <a href="{% raw %}{%{% endraw %} url '{{ application_name }}:{{ application_name }}_action_log' {% raw %}%}{% endraw %}">Activity log</a>
                <a href="{% raw %}{%{% endraw %} url '{{ application_name }}:{{ application_name }}_change_user_assignment' {% raw %}%}{% endraw %}">User assignment</a>
                {% endif %}
                {% for category in categories %}
                <b>{{ category }}</b>
                {% for page in pages %}
                {% if page.type == 'normal'%}
                {% if page.category == category.name %}
                <a href="{% raw %}{%{% endraw %} url '{{ application_name }}:render_{{ page.application }}_{{ page }}' {% raw %}%}{% endraw %}">{{ page.display_name
                    }}</a>
                {% endif %}
                {% endif %}
                {% endfor %}
                {% endfor %}

                <br>

                {% for page in pages %}
                {% if page.category in ["", none] and page.type != 'activity' %}
                <a href="{% raw %}{%{% endraw %} url '{{ application_name }}:render_{{ page.application }}_{{ page }}' {% raw %}%}{% endraw %}">{{ page.display_name
                    }}</a>
                {% endif %}
                {% endfor %}

                {% if authentication_present -%}
                {% raw %}<a href="{% url 'logout' %}">Logout</a>{% endraw %}
                {% else -%}
                {% raw %}<a href="{% url 'noauth_home-homerender' %}">Other Application</a>{% endraw %}
                {% endif -%}
            </div>
    
        <div class="content{% if has_theme %} {{ tokens.get('page.main', '') }}{% endif %}">
            {% raw %}
            <nav class="breadcrumbs" aria-label="breadcrumb">
                <a href="{% url '{% endraw %}{{ application_name }}:{{ application_name }}-homerender{% raw %}' %}">Home</a>
                {% block breadcrumbs %}{% endblock %}
            </nav>
            {% block content %}

            {% endblock %}
            {% endraw %}
        </div>
        {% endif %}
    </body>
</html>