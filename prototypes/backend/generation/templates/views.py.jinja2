{# List views #}
{% for page in pages %}
{% if models_on_pages[page]['primary_models'] %}
class {{ application_name }}_{{ page }}_ListView(GenericListView):
    {% if authentication_present -%}
    required_roles = ['{{ application_name }}']
    {% endif -%}
    template_name='{{ application_name }}_{{ page }}.html'
    model = {{ models_on_pages[page]['primary_models'][0] }}
    context_object_name = '{{ models_on_pages[page]['primary_models'][0] }}_list'

    def get_context_data(self, **kwargs):
        context = super().get_context_data(**kwargs)
        {% for model in models_on_pages[page]['parent_models'] -%}
        context['parent_{{model}}_list'] = {{model}}.objects.all()
        {% endfor -%}
        {% for primary_model in models_on_pages[page]['primary_models'][1:] -%}
        context['{{ primary_model }}_list'] = {{ primary_model }}.objects.all()
        {% endfor -%}
        # OOUX: look up the current user's active workflow node (any process, any step)
        _active_node = ActiveProcessNode.objects.filter(
            user=self.request.user,
            active_process__completed=False,
        ).select_related('action_node').first()
        context['current_action_node_id'] = _active_node.action_node.name if _active_node else None
        context['active_process_node_id'] = _active_node.id if _active_node else None
        return context

{% else %}
class {{ application_name }}_{{ page }}_ListView(GenericTemplateView):
    {% if authentication_present -%}
    required_roles = ['{{ application_name }}']
    {% endif -%}
    template_name='{{ application_name }}_{{ page }}.html'
{% endif %}
{% endfor -%}


