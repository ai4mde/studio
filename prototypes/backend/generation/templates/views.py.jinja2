from django.shortcuts import get_object_or_404
from django.urls import reverse_lazy
from django.views.generic import TemplateView
from shared_models.models import *
from shared_models.views import GenericListView, GenericCreateView, GenericUpdateView, GenericDeleteView, GenericTemplateView, GenericDetailView
from workflow_engine.models import ActiveProcess, ActiveProcessNode, Process

{# Create, Update, Delete views #}
{% for page in pages -%}
{% for section_component in page.section_components -%}

{% if section_component.has_create_operation %}
class {{ page }}_{{ section_component }}_CreateView(GenericCreateView):
    {% if authentication_present -%}
    required_roles = ['{{ application_name }}']
    {% endif -%}
    model = {{ section_component.primary_model }}
    fields = [{% for attribute in section_component.attributes %}{% if attribute.name not in ['username', 'password'] and not attribute.derived and attribute.type != AttributeType.NONE %}'{{ attribute.name }}', {% endif %}{% endfor %}]
    template_name = '{{ application_name }}_{{ page }}.html'
    success_url = reverse_lazy('{{ application_name }}:render_{{ application_name }}_{{ page }}')

    def form_valid(self, form):
        instance = form.save(commit=False)
        {% for attribute in section_component.attributes -%}
        {% if not attribute.derived -%}
        {% if attribute.type == AttributeType.BOOLEAN -%}
        instance.{{ attribute }} = (self.request.POST.get('{{ attribute }}') == 'on')
        {% elif attribute.type in [AttributeType.STRING, AttributeType.ENUM] -%}
        if not instance.{{ attribute }}:
            instance.{{ attribute }} = None
        {% endif -%}
        {% endif -%}
        {% endfor -%}
        {% for parent_model in section_component.parent_models -%}
        parent_{{ parent_model }}_pk = self.request.POST.get('{{ parent_model }}')
        if parent_{{ parent_model }}_pk:
            instance.{{ parent_model }} = get_object_or_404({{ parent_model }}, pk=parent_{{ parent_model }}_pk)
        else:
            # Check if the field allows null
            field = self.model._meta.get_field('{{ parent_model }}')
            if not field.null:
                from django.contrib import messages
                messages.error(self.request, '{{ parent_model }} is required.')
                return self.form_invalid(form)
        {% endfor -%}
        instance.save()
        # OOUX: auto-associate instance with active workflow process if one exists for this user
        _active_node = ActiveProcessNode.objects.filter(
            user=self.request.user,
            active_process__completed=False,
        ).select_related('action_node').first()
        if _active_node:
            _active_node.active_process.add_associated_instance(instance)
        return super().form_valid(form)
{% endif %}

