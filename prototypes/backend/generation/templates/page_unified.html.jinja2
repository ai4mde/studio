            {%- elif attribute.type == AttributeType.BOOLEAN %}<input type="checkbox" name="{{ attribute }}" class="h-4 w-4 rounded">
            {%- elif attribute.type == AttributeType.ENUM %}<select name="{{ attribute }}" class="{{ c.border }} border bg-white rounded px-2 py-1 {{ d.text }} {{ c.ring }} focus:outline-none focus:ring-2">{% for lit in attribute.enum_literals %}<option>{{ lit }}</option>{% endfor %}</select>
            {%- endif %}
          </td>
          {% endif %}{% endfor %}
          {% for parent_model in section_component.parent_models %}
          <td class="px-4 py-2">
            <select name="{{ parent_model }}" class="{{ c.border }} border bg-white rounded px-2 py-1 {{ d.text }} {{ c.ring }} focus:outline-none focus:ring-2">
              {% raw %}{%{% endraw %} for i in parent_{{ parent_model }}_list {% raw %}%}{% endraw %}
              {% raw %}<option value="{{ i.id }}">{{ i }}</option>{% endraw %}
              {% raw %}{% endfor %}{% endraw %}
            </select>
          </td>
          {% endfor %}
          <td class="px-4 py-2">
            <div class="flex gap-2">
              <input type="submit" value="Save" class="{{ c.btn }} text-white {{ d.text }} font-medium py-1 px-3 rounded cursor-pointer">
              <a href="{% raw %}{%{% endraw %} url '{{ application_name }}:render_{{ application_name }}_{{ page }}' {% if page.type == 'activity' %}active_process_node_id{% endif %}{% raw %}%}{% endraw %}" class="bg-gray-100 text-gray-700 {{ d.text }} py-1 px-3 rounded hover:bg-gray-200">Cancel</a>
            </div>
          </td>
          </form>
        </tr>
        {% raw %}{% endif %}{% endraw %}
        {%- endif %}
      </tbody>
    </table>
  </div>

  {%- if section_component.has_create_operation and eff_lay != "action_panel" %}
  {% raw %}{%{% endraw %} if not create_{{ section_component }} {% raw %}%}{% endraw %}
  <form action="{% raw %}{%{% endraw %} url '{{ application_name }}:render_{{ application_name }}_{{ page }}' {% if page.type == 'activity' %}active_process_node_id{% endif %}{% raw %}%}{% endraw %}" method="get" class="mt-4">
    <input type="hidden" name="create_{{ section_component }}" value="true">
