              {%- elif attribute.type == AttributeType.INTEGER %}<input type="number" name="{{ attribute }}" value="{% raw %}{{{% endraw %} update_instance.{{ attribute }} {% raw %}}}{% endraw %}" class="border border-gray-300 rounded px-2 py-1 {{ d.text }} w-full {{ c.ring }} focus:outline-none focus:ring-2">
              {%- elif attribute.type == AttributeType.BOOLEAN %}<input type="checkbox" name="{{ attribute }}" {% raw %}{%{% endraw %} if update_instance.{{ attribute }} {% raw %}%}checked{% endif %}{% endraw %} class="h-4 w-4 rounded">
              {%- elif attribute.type == AttributeType.ENUM %}<select name="{{ attribute }}" class="border border-gray-300 rounded px-2 py-1 {{ d.text }} {{ c.ring }} focus:outline-none focus:ring-2">{% for lit in attribute.enum_literals %}<option>{{ lit }}</option>{% endfor %}</select>
              {%- endif %}
            {% else %}
              {% if attribute.type == AttributeType.BOOLEAN %}<input type="checkbox" {% raw %}{%{% endraw %} if update_instance.{{ attribute }} {% raw %}%}checked{% endif %}{% endraw %} disabled class="h-4 w-4 rounded">
              {% else %}<span class="{{ d.text }} text-gray-500">{% raw %}{{{% endraw %} update_instance.{{ attribute }} {% raw %}}}{% endraw %}</span>{% endif %}
            {% endif %}
          </td>
          {% endfor %}
          {% for parent_model in section_component.parent_models %}
          <td class="px-4 py-2">
            <select name="{{ parent_model }}" class="border border-gray-300 rounded px-2 py-1 {{ d.text }} {{ c.ring }} focus:outline-none focus:ring-2">
