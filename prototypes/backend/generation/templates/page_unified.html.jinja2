                <input type="hidden" name="instance_id_{{ section_component.primary_model }}" value="{{ '{{' }}{{ section_component.primary_model }}.id{{ '}}' }}">
                <button type="submit" class="{{ d.text }} {{ c.text }} py-1 px-3 rounded hover:{{ c.light }} border {{ c.border }} transition-colors">Edit</button>
              </form>
              {%- endif %}
              {%- if section_component.has_delete_operation %}
              <form action="{% raw %}{%{% endraw %} url '{{ application_name }}:{{ page }}_{{ section_component }}_delete' {% if page.type == 'activity' %}active_process_node_id{% endif %} {{ section_component.primary_model }}.id {% raw %}%}{% endraw %}" method="post">
                {% raw %}{% csrf_token %}{% endraw %}
                <button type="submit" class="{{ d.text }} text-red-500 py-1 px-3 rounded hover:bg-red-50 border border-red-200 transition-colors">Delete</button>
              </form>
              {%- endif %}
            </div>
          </td>
          {% endif %}
        </tr>
        {%- if section_component.has_update_operation %}{% raw %}{% endif %}{% endraw %}{% endif -%}
        {% raw %}{% endfor %}{% endraw %}

        {%- if section_component.has_create_operation %}
