{#- ─────────────────────────────────────────────────────────────────
    Variant preview template — mirrors base.html.jinja2 + page.html.jinja2
    but renders static sample HTML (no Django template tags).
    Tokens are applied exactly the same way as the production templates.
   ───────────────────────────────────────────────────────────────── -#}
{%- set tokens = theme.get('tokens', {}) if theme else {} -%}
{%- set has_theme = tokens | length > 0 -%}
<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <title>{{ variant_name }} — {{ interface_name }}</title>
  {% if has_theme %}<script src="https://cdn.tailwindcss.com"></script>{% endif %}
  <style>{{ inline_css }}</style>
</head>
<body{% if has_theme %} class="{{ tokens.get('page.body', '') }}"{% endif %}>

{# ══════════════════════════════════════════════════════════════ #}
{# BASE LAYOUT — mirrors base.html.jinja2 layout branches       #}
{# ══════════════════════════════════════════════════════════════ #}

{% if layout_type == 'TOP_NAV' %}
{# ── TOP_NAV ── #}
<div class="header{% if has_theme %} {{ tokens.get('region.header', '') }}{% endif %}">
    <div class="logo"></div>
    <h1{% if has_theme %} class="{{ tokens.get('element.heading', '') }}"{% endif %}>{{ interface_name }}</h1>
</div>
<nav class="topnav{% if has_theme %} {{ tokens.get('region.nav', '') }}{% endif %}">
    <a href="#">Home</a>
    {% for p in pages %}<a href="#">{{ p.name }}</a>{% endfor %}
    <a href="#">Logout</a>
</nav>
<div class="content content-topnav{% if has_theme %} {{ tokens.get('page.main', '') }}{% endif %}">

{% elif layout_type == 'TOP_NAV_SIDEBAR' %}
{# ── TOP_NAV_SIDEBAR ── #}
<div class="header{% if has_theme %} {{ tokens.get('region.header', '') }}{% endif %}">
    <div class="logo"></div>
    <h1{% if has_theme %} class="{{ tokens.get('element.heading', '') }}"{% endif %}>{{ interface_name }}</h1>
    <nav class="topnav-inline{% if has_theme %} {{ tokens.get('region.nav', '') }}{% endif %}">
        {% for cat in categories %}<a href="#">{{ cat }}</a>{% endfor %}
        <a href="#">Logout</a>
    </nav>
</div>
<div class="menu{% if has_theme %} {{ tokens.get('region.nav', '') }}{% endif %}">
    <a href="#">Home</a>
    {% for p in pages %}<a href="#">{{ p.name }}</a>{% endfor %}
</div>
<div class="content{% if has_theme %} {{ tokens.get('page.main', '') }}{% endif %}">

{% elif layout_type == 'SIDEBAR_RIGHT' %}
{# ── SIDEBAR_RIGHT ── #}
<div class="header{% if has_theme %} {{ tokens.get('region.header', '') }}{% endif %}">
    <div class="logo"></div>
    <h1{% if has_theme %} class="{{ tokens.get('element.heading', '') }}"{% endif %}>{{ interface_name }}</h1>
</div>
<div class="content content-sidebar-right{% if has_theme %} {{ tokens.get('page.main', '') }}{% endif %}">

{% else %}
{# ── SIDEBAR_LEFT (default) ── #}
<div class="header{% if has_theme %} {{ tokens.get('region.header', '') }}{% endif %}">
    <div class="logo"></div>
    <h1{% if has_theme %} class="{{ tokens.get('element.heading', '') }}"{% endif %}>{{ interface_name }}</h1>
</div>
<div class="menu{% if has_theme %} {{ tokens.get('region.nav', '') }}{% endif %}">
    <a href="#">Home</a>
    {% for p in pages %}<a href="#">{{ p.name }}</a>{% endfor %}
    <a href="#">Logout</a>
</div>
<div class="content{% if has_theme %} {{ tokens.get('page.main', '') }}{% endif %}">
{% endif %}

{# ── Breadcrumbs ── #}
<nav class="breadcrumbs" aria-label="breadcrumb">
    <a href="#">Home</a>
    {% if first_page.category %}
    <span class="breadcrumb-sep">/</span><span>{{ first_page.category }}</span>
    {% endif %}
    <span class="breadcrumb-sep">/</span>
    <span class="breadcrumb-current">{{ first_page.name }}</span>
</nav>

{# ══════════════════════════════════════════════════════════════ #}
{# PAGE CONTENT — mirrors page.html.jinja2                      #}
{# ══════════════════════════════════════════════════════════════ #}

<div{% if has_theme %} class="{{ tokens.get('page.surface', '') }}"{% endif %}>

{% if screen_type == 'dashboard' %}
{# ═══ DASHBOARD ═══ #}
<h2{% if has_theme %} class="{{ tokens.get('element.heading', '') }}"{% endif %}>{{ first_page.name }}</h2>
<div class="dashboard-cards{% if has_theme %} {{ tokens.get('region.dashboard', '') }}{% endif %}">
    {% for sec in page_sections %}
    <div class="dashboard-card{% if has_theme %} {{ tokens.get('component.card', '') }}{% endif %}">
        <div class="dashboard-card-header">
            <h3{% if has_theme %} class="{{ tokens.get('element.heading', '') }}"{% endif %}>{{ sec.name }}</h3>
        </div>
        <div class="dashboard-card-value">{{ 12 + loop.index * 7 }}</div>
        <div class="dashboard-card-label"{% if has_theme %} class="{{ tokens.get('element.label', '') }}"{% endif %}>Total Records</div>
    </div>
    {% endfor %}
</div>
{% for sec in page_sections %}
<div class="dashboard-section{% if has_theme %} {{ tokens.get('component.card', '') }}{% endif %}">
    <div class="dashboard-section-header">
        <h3{% if has_theme %} class="{{ tokens.get('element.heading', '') }}"{% endif %}>Recent {{ sec.name }}</h3>
    </div>
    <table{% if has_theme %} class="{{ tokens.get('component.table', '') }}"{% endif %}>
        <thead><tr>
            {% for attr in sec.attributes[:6] %}
            <th{% if has_theme %} class="{{ tokens.get('element.th', '') }}"{% endif %}>{{ attr.name }}</th>
            {% endfor %}
        </tr></thead>
        <tbody>
            {% for row_i in range(3) %}
            <tr>
                {% for attr in sec.attributes[:6] %}
                <td{% if has_theme %} class="{{ tokens.get('element.td', '') }}"{% endif %} style="text-align:center;">
                    {%- if attr.type in ('int','float','number') %}{{ 10 + row_i * 5 }}
                    {%- elif attr.type == 'date' %}2024-01-{{ '%02d' | format(10 + row_i) }}
                    {%- elif attr.type == 'bool' %}<input type="checkbox" disabled{{ ' checked' if row_i % 2 == 0 else '' }}>
                    {%- else %}Sample {{ row_i + 1 }}{% endif -%}
                </td>
                {% endfor %}
            </tr>
            {% endfor %}
        </tbody>
    </table>
</div>
{% endfor %}

{% elif screen_type == 'form' %}
{# ═══ STANDALONE FORM ═══ #}
{% for sec in page_sections %}
<div class="standalone-form-container{% if has_theme %} {{ tokens.get('component.card', '') }} {{ tokens.get('region.form', '') }}{% endif %}">
    <h2{% if has_theme %} class="{{ tokens.get('element.heading', '') }}"{% endif %}>{{ sec.name }}</h2>
    <form onsubmit="return false;" class="standalone-form{% if has_theme %} {{ tokens.get('region.form', '') }}{% endif %}">
        {% for attr in sec.attributes[:8] %}
        <div class="form-group">
            <label{% if has_theme %} class="{{ tokens.get('element.label', '') }}"{% endif %}>{{ attr.name }}</label>
            {% if attr.type == 'bool' %}
            <input type="checkbox"{% if has_theme %} class="{{ tokens.get('element.input.editable', '') }}"{% endif %}>
            {% elif attr.type in ('int','float','number') %}
            <input type="number" placeholder="{{ attr.name }}"{% if has_theme %} class="{{ tokens.get('element.input.editable', '') }}"{% endif %}>
            {% elif attr.type == 'date' %}
            <input type="date"{% if has_theme %} class="{{ tokens.get('element.input.editable', '') }}"{% endif %}>
            {% else %}
            <input type="text" placeholder="{{ attr.name }}"{% if has_theme %} class="{{ tokens.get('element.input.editable', '') }}"{% endif %}>
            {% endif %}
        </div>
        {% endfor %}
        <div class="form-actions">
            <button type="submit" class="btn-save{% if has_theme %} {{ tokens.get('component.button.primary', '') }}{% endif %}">Save</button>
            <button type="button" class="btn-cancel{% if has_theme %} {{ tokens.get('component.button.secondary', '') }}{% endif %}">Cancel</button>
        </div>
    </form>
</div>
{% endfor %}

{% elif screen_type == 'wizard' %}
{# ═══ WIZARD ═══ #}
<div class="wizard-container{% if has_theme %} {{ tokens.get('component.card', '') }} {{ tokens.get('region.wizard', '') }}{% endif %}">
    <div class="wizard-steps{% if has_theme %} {{ tokens.get('region.wizard.step', '') }}{% endif %}">
        {% for sec in page_sections %}
        <div class="wizard-step{% if loop.first %} wizard-step-active{% endif %}">
            <span class="wizard-step-number">{{ loop.index }}</span>
            <span>{{ sec.name }}</span>
        </div>
        {% if not loop.last %}<div class="wizard-step-connector"></div>{% endif %}
        {% endfor %}
    </div>
    {% for sec in page_sections %}
    <div class="wizard-panel{% if loop.first %} wizard-panel-active{% endif %}" id="wizard-panel-{{ loop.index }}">
        <h3{% if has_theme %} class="{{ tokens.get('element.heading', '') }}"{% endif %}>{{ sec.name }}</h3>
        <form onsubmit="return false;" id="wizard-form-{{ loop.index }}" class="{% if has_theme %}{{ tokens.get('region.form', '') }}{% endif %}">
            {% for attr in sec.attributes[:6] %}
            <div class="form-group">
                <label{% if has_theme %} class="{{ tokens.get('element.label', '') }}"{% endif %}>{{ attr.name }}</label>
                {% if attr.type == 'bool' %}
                <input type="checkbox"{% if has_theme %} class="{{ tokens.get('element.input.editable', '') }}"{% endif %}>
                {% elif attr.type in ('int','float','number') %}
                <input type="number" placeholder="{{ attr.name }}"{% if has_theme %} class="{{ tokens.get('element.input.editable', '') }}"{% endif %}>
                {% else %}
                <input type="text" placeholder="{{ attr.name }}"{% if has_theme %} class="{{ tokens.get('element.input.editable', '') }}"{% endif %}>
                {% endif %}
            </div>
            {% endfor %}
        </form>
    </div>
    {% endfor %}
    <div class="wizard-nav">
        <button class="wizard-prev{% if has_theme %} {{ tokens.get('component.button.secondary', '') }}{% endif %}" disabled>&larr; Previous</button>
        <button class="wizard-next{% if has_theme %} {{ tokens.get('component.button.primary', '') }}{% endif %}">Next &rarr;</button>
    </div>
</div>

{% elif screen_type == 'modal' %}
{# ═══ MODAL ═══ #}
{% for sec in page_sections %}
<div class="modal-page-wrapper">
    <div class="modal-page-card{% if has_theme %} {{ tokens.get('component.card', '') }} {{ tokens.get('region.modal', '') }}{% endif %}">
        <h2{% if has_theme %} class="{{ tokens.get('element.heading', '') }}"{% endif %}>{{ sec.name }}</h2>
        <form onsubmit="return false;" class="{% if has_theme %}{{ tokens.get('region.form', '') }}{% endif %}">
            {% for attr in sec.attributes[:6] %}
            <div class="form-group">
                <label{% if has_theme %} class="{{ tokens.get('element.label', '') }}"{% endif %}>{{ attr.name }}</label>
                <input type="text" placeholder="{{ attr.name }}"{% if has_theme %} class="{{ tokens.get('element.input.editable', '') }}"{% endif %}>
            </div>
            {% endfor %}
            <div class="modal-actions">
                <button type="submit" class="btn-save{% if has_theme %} {{ tokens.get('component.button.primary', '') }}{% endif %}">Confirm</button>
                <button type="button" class="btn-cancel{% if has_theme %} {{ tokens.get('component.button.secondary', '') }}{% endif %}">Cancel</button>
            </div>
        </form>
    </div>
</div>
{% endfor %}

{% else %}
{# ═══ LIST (default) — mirrors page.html.jinja2 list layout ═══ #}

{# Tabs #}
{% if page_sections | length > 1 %}
<div class="tabs" role="tablist">
    {% for sec in page_sections %}
    <button class="tab-btn{% if loop.first %} tab-active{% endif %}" role="tab"
            aria-selected="{{ 'true' if loop.first else 'false' }}" data-tab="tab-{{ loop.index }}">
        {{ sec.name }}
    </button>
    {% endfor %}
</div>
{% endif %}

{% for sec in page_sections %}

{# Tab panel wrapper #}
{% if page_sections | length > 1 %}
<div class="tab-panel{% if loop.first %} tab-panel-active{% endif %}" id="tab-{{ loop.index }}" role="tabpanel">
{% endif %}

{# Section header with accordion #}
<div class="section-header" data-accordion="section-body-{{ loop.index }}">
    <h2{% if has_theme %} class="{{ tokens.get('element.heading', '') }}"{% endif %}>{{ sec.name }}</h2>
    <span class="accordion-icon">&#9660;</span>
</div>

<div class="section-body{% if has_theme %} {{ tokens.get('component.card', '') }}{% endif %}" id="section-body-{{ loop.index }}">

{# Search bar #}
<div class="search-bar">
    <input type="text" class="search-input" placeholder="Search..." data-table="table-{{ loop.index }}">
</div>

{# Table #}
<table id="table-{{ loop.index }}"{% if has_theme %} class="{{ tokens.get('component.table', '') }}"{% endif %}>
    <thead><tr>
        {% for attr in sec.attributes[:6] %}
        <th{% if has_theme %} class="{{ tokens.get('element.th', '') }}"{% endif %}>{{ attr.name }}</th>
        {% endfor %}
        <th{% if has_theme %} class="{{ tokens.get('element.th', '') }}"{% endif %}></th>
        <th{% if has_theme %} class="{{ tokens.get('element.th', '') }}"{% endif %}></th>
    </tr></thead>
    <tbody>
        {% for row_i in range(3) %}
        <tr>
            {% for attr in sec.attributes[:6] %}
            <td{% if has_theme %} class="{{ tokens.get('element.td', '') }}"{% endif %} style="text-align:center;">
                {%- if attr.type in ('int','float','number') %}{{ 10 + row_i * 5 }}
                {%- elif attr.type == 'date' %}2024-01-{{ '%02d' | format(10 + row_i) }}
                {%- elif attr.type == 'bool' %}<input type="checkbox" disabled{{ ' checked' if row_i % 2 == 0 else '' }}>
                {%- else %}Sample {{ row_i + 1 }}{% endif -%}
            </td>
            {% endfor %}
            {# Edit icon #}
            <td><svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M21.28 6.4L11.74 15.94C10.79 16.89 7.97 17.33 7.34 16.7C6.71 16.07 7.14 13.25 8.09 12.3L17.64 2.75C18.43 1.94 19.71 1.94 20.5 2.73C21.29 3.51 21.29 4.79 20.5 5.58Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><path d="M11 4H6C4.94 4 3.92 4.42 3.17 5.17C2.42 5.92 2 6.94 2 8V18C2 19.06 2.42 20.08 3.17 20.83C3.92 21.58 4.94 22 6 22H17C19.21 22 20 20.2 20 18V13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></td>
            {# Delete icon #}
            <td><svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M10 12V17" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/><path d="M14 12V17" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/><path d="M4 7H20" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/><path d="M6 10V18C6 19.66 7.34 21 9 21H15C16.66 21 18 19.66 18 18V10" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/><path d="M9 5C9 3.9 9.9 3 11 3H13C14.1 3 15 3.9 15 5V7H9V5Z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg></td>
        </tr>
        {% endfor %}
    </tbody>
</table>

{# Pagination #}
<div class="pagination" data-table="table-{{ loop.index }}">
    <button class="page-btn page-prev" disabled>&laquo; Prev</button>
    <span class="page-info">Page <span class="page-current">1</span></span>
    <button class="page-btn page-next">Next &raquo;</button>
</div>

{# Create button + modal #}
<button class="create-open-btn{% if has_theme %} {{ tokens.get('component.button.primary', '') }}{% endif %}" data-modal="modal-create-{{ loop.index }}">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M15 12H12M12 12H9M12 12V9M12 12V15M17 21H7C4.79 21 3 19.21 3 17V7C3 4.79 4.79 3 7 3H17C19.21 3 21 4.79 21 7V17C21 19.21 19.21 21 17 21Z" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
    Add {{ sec.name }}
</button>

{# Create modal #}
<div class="modal-overlay" id="modal-create-{{ loop.index }}">
    <div class="modal{% if has_theme %} {{ tokens.get('page.surface', '') }}{% endif %}">
        <div class="modal-header">
            <h3{% if has_theme %} class="{{ tokens.get('element.heading', '') }}"{% endif %}>Create {{ sec.name }}</h3>
            <button class="modal-close">&times;</button>
        </div>
        <div class="modal-body">
            <form onsubmit="return false;" class="modal-form{% if has_theme %} {{ tokens.get('region.form', '') }}{% endif %}">
                {% for attr in sec.attributes[:6] %}
                <div class="form-group">
                    <label{% if has_theme %} class="{{ tokens.get('element.label', '') }}"{% endif %}>{{ attr.name }}</label>
                    {% if attr.type == 'bool' %}
                    <input type="checkbox"{% if has_theme %} class="{{ tokens.get('element.input.editable', '') }}"{% endif %}>
                    {% elif attr.type in ('int','float','number') %}
                    <input type="number" placeholder="{{ attr.name }}"{% if has_theme %} class="{{ tokens.get('element.input.editable', '') }}"{% endif %}>
                    {% elif attr.type == 'date' %}
                    <input type="date"{% if has_theme %} class="{{ tokens.get('element.input.editable', '') }}"{% endif %}>
                    {% else %}
                    <input type="text" placeholder="{{ attr.name }}"{% if has_theme %} class="{{ tokens.get('element.input.editable', '') }}"{% endif %}>
                    {% endif %}
                </div>
                {% endfor %}
                <div class="modal-actions">
                    <button type="submit" class="btn-save{% if has_theme %} {{ tokens.get('component.button.primary', '') }}{% endif %}">Save</button>
                    <button type="button" class="btn-cancel modal-close{% if has_theme %} {{ tokens.get('component.button.secondary', '') }}{% endif %}">Cancel</button>
                </div>
            </form>
        </div>
    </div>
</div>

</div>{# /section-body #}

{% if page_sections | length > 1 %}
</div>{# /tab-panel #}
{% endif %}

{% endfor %}

{% endif %}{# /screen_type #}

</div>{# /page.surface #}
</div>{# /content #}

{# ── Right sidebar for SIDEBAR_RIGHT layout ── #}
{% if layout_type == 'SIDEBAR_RIGHT' %}
<div class="menu menu-right{% if has_theme %} {{ tokens.get('region.nav', '') }}{% endif %}">
    <a href="#">Home</a>
    {% for p in pages %}<a href="#">{{ p.name }}</a>{% endfor %}
    <a href="#">Logout</a>
</div>
{% endif %}

{# ── JavaScript — identical to page.html.jinja2 ── #}
<script>
(function(){
    document.querySelectorAll('.tab-btn').forEach(function(btn){
        btn.addEventListener('click', function(){
            var tabId = this.getAttribute('data-tab');
            this.closest('.tabs').querySelectorAll('.tab-btn').forEach(function(b){ b.classList.remove('tab-active'); b.setAttribute('aria-selected','false'); });
            this.classList.add('tab-active'); this.setAttribute('aria-selected','true');
            document.querySelectorAll('.tab-panel').forEach(function(p){ p.classList.remove('tab-panel-active'); });
            document.getElementById(tabId).classList.add('tab-panel-active');
        });
    });
    document.querySelectorAll('.search-input').forEach(function(input){
        input.addEventListener('input', function(){
            var q = this.value.toLowerCase(), tableId = this.getAttribute('data-table');
            document.querySelectorAll('#'+tableId+' tbody tr').forEach(function(row){ row.style.display = row.textContent.toLowerCase().indexOf(q) > -1 ? '' : 'none'; });
        });
    });
    var PAGE_SIZE = 10;
    document.querySelectorAll('.pagination').forEach(function(pag){
        var tableId = pag.getAttribute('data-table'), rows = document.querySelectorAll('#'+tableId+' tbody tr');
        var cur = 1, total = Math.max(1, Math.ceil(rows.length / PAGE_SIZE));
        function render(){ rows.forEach(function(r,i){ r.style.display = (i>=(cur-1)*PAGE_SIZE && i<cur*PAGE_SIZE)?'':'none'; });
            pag.querySelector('.page-current').textContent=cur; pag.querySelector('.page-prev').disabled=cur<=1; pag.querySelector('.page-next').disabled=cur>=total;
            if(rows.length<=PAGE_SIZE) pag.style.display='none'; }
        pag.querySelector('.page-prev').addEventListener('click', function(){ if(cur>1){cur--;render();} });
        pag.querySelector('.page-next').addEventListener('click', function(){ if(cur<total){cur++;render();} });
        render();
    });
    document.querySelectorAll('.create-open-btn').forEach(function(btn){
        btn.addEventListener('click', function(){ document.getElementById(this.getAttribute('data-modal')).classList.add('modal-visible'); });
    });
    document.querySelectorAll('.modal-close').forEach(function(btn){
        btn.addEventListener('click', function(){ this.closest('.modal-overlay').classList.remove('modal-visible'); });
    });
    document.querySelectorAll('.modal-overlay').forEach(function(overlay){
        overlay.addEventListener('click', function(e){ if(e.target===this) this.classList.remove('modal-visible'); });
    });
    document.querySelectorAll('.section-header[data-accordion]').forEach(function(header){
        header.addEventListener('click', function(){
            var body = document.getElementById(this.getAttribute('data-accordion')), icon = this.querySelector('.accordion-icon');
            if(body.classList.contains('section-body-collapsed')){ body.classList.remove('section-body-collapsed'); icon.textContent='\u25BC'; }
            else { body.classList.add('section-body-collapsed'); icon.textContent='\u25B6'; }
        });
    });
    (function(){
        var panels=document.querySelectorAll('.wizard-panel'), steps=document.querySelectorAll('.wizard-step'),
            prevBtn=document.querySelector('.wizard-prev'), nextBtn=document.querySelector('.wizard-next');
        if(!panels.length) return;
        var cur=1, total=panels.length;
        function show(n){ panels.forEach(function(p){p.classList.remove('wizard-panel-active');}); steps.forEach(function(s){s.classList.remove('wizard-step-active','wizard-step-done');});
            var t=document.getElementById('wizard-panel-'+n); if(t) t.classList.add('wizard-panel-active');
            for(var i=0;i<steps.length;i++){if(i+1<n) steps[i].classList.add('wizard-step-done'); if(i+1===n) steps[i].classList.add('wizard-step-active');}
            if(prevBtn) prevBtn.disabled=(n<=1); if(nextBtn){nextBtn.style.display=n>=total?'none':'';} }
        if(prevBtn) prevBtn.addEventListener('click', function(){ if(cur>1){cur--;show(cur);} });
        if(nextBtn) nextBtn.addEventListener('click', function(){ if(cur<total){cur++;show(cur);} });
    })();
})();
</script>
</body>
</html>
